@implements IDisposable
@inject ConfirmService ConfirmSvc

@if (_visible)
{
    @* Backdrop *@
    <div style="position:fixed; inset:0; z-index:900; background:rgba(0,0,0,0.45); display:flex; align-items:center; justify-content:center; padding:16px; animation:fadeIn 0.15s ease;"
         @onclick="Cancel">

        @* Card — stopPropagation prevents backdrop click from dismissing *@
        <div style="background:var(--bg); border-radius:var(--r-lg); padding:24px 20px; max-width:320px; width:100%; box-shadow:0 20px 60px rgba(0,0,0,0.25); animation:slideUp 0.18s ease;"
             @onclick:stopPropagation="true">

            @* Icon *@
            <div style="display:flex; justify-content:center; margin-bottom:16px;">
                <div style="width:52px; height:52px; border-radius:var(--r-full); background:@_iconBg; display:flex; align-items:center; justify-content:center;">
                    <i class="fa-solid @_icon" style="font-size:22px; color:@_iconColor;"></i>
                </div>
            </div>

            @* Title *@
            <div style="font-family:var(--font); font-size:16px; font-weight:700; color:var(--text); text-align:center; margin-bottom:8px; letter-spacing:-0.01em;">
                @_opts.Title
            </div>

            @* Message *@
            <div style="font-family:var(--font); font-size:13px; color:var(--text-3); text-align:center; line-height:1.5; margin-bottom:22px;">
                @_opts.Message
            </div>

            @* Buttons *@
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                <button @onclick="Cancel"
                        style="padding:12px 8px; border-radius:var(--r-lg); border:1px solid var(--border); background:var(--bg-page); color:var(--text-2); font-family:var(--font); font-size:14px; font-weight:600; cursor:pointer; -webkit-appearance:none;">
                    @_opts.CancelLabel
                </button>
                <button @onclick="Confirm"
                        style="padding:12px 8px; border-radius:var(--r-lg); border:1px solid @_btnBorder; background:@_btnBg; color:@_btnColor; font-family:var(--font); font-size:14px; font-weight:600; cursor:pointer; -webkit-appearance:none;">
                    @_opts.ConfirmLabel
                </button>
            </div>
        </div>
    </div>
}

<style>
    @@keyframes fadeIn  { from { opacity:0; } to { opacity:1; } }
    @@keyframes slideUp { from { transform:translateY(12px); opacity:0; } to { transform:translateY(0); opacity:1; } }
</style>

@code {
    private bool           _visible;
    private ConfirmOptions _opts = new();

    // Computed style tokens per variant
    private string _icon       = "fa-triangle-exclamation";
    private string _iconBg     = "#FEE2E2";
    private string _iconColor  = "#DC2626";
    private string _btnBg      = "#EF4444";
    private string _btnBorder  = "#EF4444";
    private string _btnColor   = "white";

    protected override void OnInitialized() =>
        ConfirmSvc.OnShow += OnShow;

    private void OnShow(ConfirmOptions opts)
    {
        _opts = opts;
        ApplyVariant(opts.Variant);
        _visible = true;
        InvokeAsync(StateHasChanged);
    }

    private void ApplyVariant(string variant)
    {
        switch (variant)
        {
            case "success":
                _icon      = "fa-circle-check";
                _iconBg    = "#D1FAE5";
                _iconColor = "#059669";
                _btnBg     = "#10B981";
                _btnBorder = "#10B981";
                _btnColor  = "white";
                break;

            case "warning":
                _icon      = "fa-triangle-exclamation";
                _iconBg    = "#FEF3C7";
                _iconColor = "#D97706";
                _btnBg     = "#F59E0B";
                _btnBorder = "#F59E0B";
                _btnColor  = "white";
                break;

            default: // danger
                _icon      = "fa-triangle-exclamation";
                _iconBg    = "#FEE2E2";
                _iconColor = "#DC2626";
                _btnBg     = "#EF4444";
                _btnBorder = "#EF4444";
                _btnColor  = "white";
                break;
        }
    }

    private void Confirm()
    {
        _visible = false;
        ConfirmSvc.Complete(true);
    }

    private void Cancel()
    {
        _visible = false;
        ConfirmSvc.Complete(false);
    }

    public void Dispose() =>
        ConfirmSvc.OnShow -= OnShow;
}
