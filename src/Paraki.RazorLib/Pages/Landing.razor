@page "/inicio"
@inject NavigationManager Nav
@inject AuthService AuthService

<div style="min-height:100vh; display:flex; flex-direction:column; background:var(--bg-page);">

    <!-- Hero -->
    <div style="background:linear-gradient(160deg, var(--brand) 0%, var(--brand-dark) 100%); flex-shrink:0;">
        <StatusBar Dark="true" />

        <!-- Top bar -->
        <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 24px 0;">
            <span style="font-size:20px; font-weight:900; color:white; font-family:var(--font); letter-spacing:-0.05em;">Paraki</span>
            @if (_user is null)
            {
                <a href="/login"
                   style="font-size:14px; font-weight:600; color:rgba(255,255,255,0.85); font-family:var(--font); text-decoration:none; padding:6px 14px; border-radius:var(--r-full); background:rgba(255,255,255,0.14); border:1px solid rgba(255,255,255,0.22);">
                    Entrar
                </a>
            }
            else
            {
                <a href="/perfil" style="display:block; width:36px; height:36px; border-radius:var(--r-full); background:rgba(255,255,255,0.18); border:2px solid rgba(255,255,255,0.4); overflow:hidden; flex-shrink:0;">
                    @if (!string.IsNullOrEmpty(_user.FotoPerfilUrl))
                    {
                        <img src="@_user.FotoPerfilUrl" alt="Perfil" style="width:100%; height:100%; object-fit:cover;" />
                    }
                    else
                    {
                        <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center;">
                            <i class="fa-solid fa-user" style="font-size:15px; color:white;"></i>
                        </div>
                    }
                </a>
            }
        </div>

        <!-- Hero content -->
        <div style="padding:48px 28px 60px; text-align:center; max-width:560px; margin:0 auto; box-sizing:border-box;">
            <div style="width:80px; height:80px; border-radius:22px; background:rgba(255,255,255,0.18); backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px); border:1.5px solid rgba(255,255,255,0.28); margin:0 auto 24px; display:flex; align-items:center; justify-content:center;">
                <img src="_content/Paraki.RazorLib/icon-192.png" alt="Paraki" style="width:54px; height:54px; object-fit:contain; border-radius:14px;" />
            </div>

            <p style="font-size:16px; font-weight:700; color:rgba(255,255,255,0.7); font-family:var(--font); margin:0 0 12px; letter-spacing:0.04em; text-transform:uppercase;">
                Busca. Acha. <span style="color:white;">Paraki.</span>
            </p>
            <h1 style="font-size:30px; font-weight:900; color:white; font-family:var(--font); letter-spacing:-0.04em; margin:0 0 14px; line-height:1.15;">
                O mapa colaborativo da micromobilidade urbana
            </h1>
            <p style="font-size:15px; color:rgba(255,255,255,0.78); font-family:var(--font); margin:0 0 36px; line-height:1.65;">
                Encontre bicicletários, avalie condições e ajude ciclistas e usuários de patinetes a se moverem melhor pela cidade.
            </p>

            <!-- CTAs -->
            <div style="display:flex; flex-direction:column; gap:12px; max-width:300px; margin:0 auto;">
                @if (_user is null)
                {
                    <a href="/login"
                       style="display:block; padding:15px; background:white; color:var(--brand); border-radius:var(--r-xl); font-size:16px; font-weight:700; font-family:var(--font); text-decoration:none; text-align:center; letter-spacing:-0.01em;">
                        Criar conta grátis
                    </a>
                    <a href="/login"
                       style="display:block; padding:14px; background:rgba(255,255,255,0.13); border:1.5px solid rgba(255,255,255,0.28); color:rgba(255,255,255,0.9); border-radius:var(--r-xl); font-size:15px; font-weight:500; font-family:var(--font); text-decoration:none; text-align:center; backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px);">
                        Já tenho conta — entrar
                    </a>
                }
                <a href="/"
                   style="display:block; padding:10px; color:rgba(255,255,255,0.6); font-size:13px; font-family:var(--font); text-decoration:none; text-align:center;">
                    @(_user is null ? "Explorar o mapa sem conta →" : "Explorar mapa →")
                </a>
            </div>
        </div>
    </div>

    <!-- Features -->
    <div style="padding:40px 20px 0; max-width:640px; width:100%; margin:0 auto; box-sizing:border-box;">
        <p style="text-align:center; font-size:11px; font-weight:700; color:var(--text-4); font-family:var(--font); letter-spacing:0.08em; text-transform:uppercase; margin:0 0 24px;">Por que usar o Paraki</p>

        <div style="background:var(--bg); border-radius:var(--r-xl); border:1px solid var(--border); padding:4px 0; box-shadow:var(--shadow-sm);">

            @foreach (var (icon, titulo, desc, last) in _features)
            {
                <div style="display:flex; align-items:flex-start; gap:14px; padding:18px 20px;">
                    <div style="width:40px; height:40px; border-radius:var(--r); background:var(--brand-soft); display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:1px;">
                        <i class="fa-solid @icon" style="font-size:16px; color:var(--brand);"></i>
                    </div>
                    <div>
                        <p style="font-size:15px; font-weight:700; color:var(--text); font-family:var(--font); margin:0 0 4px;">@titulo</p>
                        <p style="font-size:13px; color:var(--text-3); font-family:var(--font); margin:0; line-height:1.6;">@desc</p>
                    </div>
                </div>
                @if (!last)
                {
                    <div style="height:1px; background:var(--border); margin:0 20px;"></div>
                }
            }

        </div>
    </div>

    <!-- Final CTA -->
    <div style="padding:32px 20px; max-width:640px; width:100%; margin:0 auto; box-sizing:border-box;">
        <div style="background:var(--brand-soft); border-radius:var(--r-xl); padding:28px 24px; text-align:center;">
            <i class="fa-solid fa-map-location-dot" style="font-size:28px; color:var(--brand); margin-bottom:12px; display:block;"></i>
            <p style="font-size:18px; font-weight:800; color:var(--text); font-family:var(--font); margin:0 0 6px; letter-spacing:-0.02em;">Pronto para explorar?</p>
            <p style="font-size:14px; color:var(--text-3); font-family:var(--font); margin:0 0 20px; line-height:1.6;">
                Junte-se à comunidade e ajude a mapear a infraestrutura de micromobilidade da sua cidade.
            </p>
            <a href="@(_user is null ? "/login" : "/")"
               style="display:inline-block; padding:13px 28px; background:var(--brand); color:white; border-radius:var(--r-full); font-size:15px; font-weight:700; font-family:var(--font); text-decoration:none;">
                Começar agora
            </a>
        </div>
    </div>

    <!-- Footer -->
    <div style="margin-top:auto; padding:24px 20px 40px; border-top:1px solid var(--border);">
        <p style="text-align:center; font-size:13px; color:var(--text-4); font-family:var(--font); margin:0 0 4px;">© 2026 Maverick Software Solutions</p>
        <p style="text-align:center; font-size:12px; color:var(--text-4); font-family:var(--font); margin:0 0 12px;">65.483.350 HEITOR MACIEL DE VASCONCELLOS LEITE &nbsp;·&nbsp; CNPJ 65.483.350/0001-00 &nbsp;·&nbsp; MEI</p>
        <div style="display:flex; align-items:center; justify-content:center; flex-wrap:wrap; gap:20px;">
            <a href="/sobre"                    style="font-size:13px; color:var(--text-3); font-family:var(--font); text-decoration:none; font-weight:500;">Sobre</a>
            <a href="/politica-de-privacidade"  style="font-size:13px; color:var(--text-3); font-family:var(--font); text-decoration:none; font-weight:500;">Privacidade</a>
            <a href="/termos-de-uso"            style="font-size:13px; color:var(--text-3); font-family:var(--font); text-decoration:none; font-weight:500;">Termos</a>
            <a href="/contato"                  style="font-size:13px; color:var(--text-3); font-family:var(--font); text-decoration:none; font-weight:500;">Contato</a>
        </div>
    </div>

</div>

@code {
    private UserInfo? _user;

    protected override async Task OnInitializedAsync()
    {
        _user = await AuthService.GetUserInfoAsync();
        if (_user?.FotoPerfilUrl is not null)
            _user.FotoPerfilUrl = AuthService.ResolveUrl(_user.FotoPerfilUrl);
    }

    private readonly (string Icon, string Titulo, string Desc, bool Last)[] _features =
    [
        ("fa-map-location-dot", "Mapa colaborativo em tempo real",  "Veja bicicletários próximos no mapa, com filtros por tipo de acesso, serviços disponíveis e nota mínima.", false),
        ("fa-star",             "Avalie e ajude a comunidade",      "Dê uma nota, deixe um comentário e ajude outros usuários a escolher o melhor local para estacionar.", false),
        ("fa-sliders",          "Para toda micromobilidade",         "Bicicletas, patinetes, scooters e monociclos — filtre especificamente para o seu veículo.", false),
        ("fa-plus-circle",      "Contribua com novos locais",        "Não achou seu bicicletário favorito? Adicione-o ao mapa em poucos passos.", true),
    ];
}
