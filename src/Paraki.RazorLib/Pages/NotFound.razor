@page "/not-found"
@layout MainLayout
@inject NavigationManager Nav

<div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:60vh; gap:16px; font-family:var(--wf-font); text-align:center; padding:32px;">
    <i class="fa-solid fa-map-location-dot" style="font-size:48px; color:var(--border);"></i>
    <div style="font-size:22px; font-weight:700; color:var(--text);">Página não encontrada</div>
    <div style="font-size:15px; color:var(--text-4);">O conteúdo que você procura não existe.</div>
    <div style="margin-top:8px; width:100%;">
        <BtnP OnClick="@(() => Nav.NavigateTo("/"))">VOLTAR AO INÍCIO</BtnP>
    </div>
</div>
