@page "/adicionar"
@layout MainLayout
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IHttpClientFactory HttpFactory
@inject AuthService AuthService
@inject BicicletarioService BicicletarioSvc
@inject ToastService ToastSvc
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.Json
@using System.Text.Json.Serialization
@using System.Net.Http.Headers

@* ── Loading ───────────────────────────────────────────────────── *@
@if (_isPc is null)
{
    <div style="height:100vh;"></div>
}

@* ── Acesso restrito ───────────────────────────────────────────── *@
else if (!_isAuthenticated)
{
    <div style="display:flex;align-items:center;justify-content:center;min-height:calc(100vh - 60px);padding:40px 24px;">
        <div style="text-align:center;max-width:320px;display:flex;flex-direction:column;align-items:center;gap:16px;">
            <div style="width:64px;height:64px;border-radius:var(--r-full);background:var(--bg-page);border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;">
                <i class="fa-solid fa-lock" style="font-size:24px;color:var(--text-4);"></i>
            </div>
            <div>
                <div style="font-size:17px;font-weight:700;color:var(--text);font-family:var(--font);letter-spacing:-0.02em;margin-bottom:6px;">Acesso restrito</div>
                <div style="font-size:14px;color:var(--text-3);font-family:var(--font);line-height:1.5;">Para adicionar um bicicletário você precisa estar logado.</div>
            </div>
            <BtnP Style="width:100%;margin-top:8px;" OnClick="@(() => Nav.NavigateTo("/login"))">
                <i class="fa-solid fa-right-to-bracket" style="margin-right:8px;"></i> Fazer login
            </BtnP>
        </div>
    </div>
}

@* ── PC: 3 colunas ─────────────────────────────────────────────── *@
else if (_isPc == true)
{
<div class="adicionar-pc-layout">

    @* Coluna 1 — Localização *@
    <div class="adicionar-pc-col">
        <div class="adicionar-pc-col-hdr">
            <SecLabel>Localização</SecLabel>
        </div>
        <div class="adicionar-pc-map-wrap">
            <MapGrid @ref="_map" H="0" />
            <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-100%);pointer-events:none;z-index:400;">
                <i class="fa-solid fa-location-dot" style="color:var(--brand);font-size:40px;filter:drop-shadow(0 3px 8px rgba(125,17,40,0.45));"></i>
            </div>
            <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:30px;height:30px;border:2px dashed rgba(125,17,40,0.3);border-radius:var(--r-full);margin-top:2px;pointer-events:none;z-index:400;"></div>
            <div class="adicionar-map-overlay">
                <div style="display:flex;gap:6px;">
                    <div style="flex:1;position:relative;">
                        <i class="fa-solid fa-magnifying-glass" style="position:absolute;left:11px;top:50%;transform:translateY(-50%);color:var(--text-4);font-size:11px;pointer-events:none;z-index:1;"></i>
                        <input type="text" value="@_searchText"
                               @oninput="@((e) => _searchText = e.Value?.ToString() ?? "")"
                               @onkeydown="OnSearchKeyDown"
                               placeholder="Buscar endereço..."
                               style="width:100%;border:1.5px solid var(--border);border-radius:var(--r);padding:9px 10px 9px 32px;background:var(--bg);color:var(--text);font-size:13px;font-family:var(--font);-webkit-appearance:none;box-sizing:border-box;" />
                    </div>
                    <button @onclick="SearchAddressAsync"
                            style="width:38px;height:38px;border-radius:var(--r);background:var(--brand);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;opacity:@(_isSearching ? "0.6" : "1");">
                        @if (_isSearching) { <i class="fa-solid fa-spinner fa-spin" style="color:white;font-size:11px;"></i> }
                        else               { <i class="fa-solid fa-magnifying-glass" style="color:white;font-size:11px;"></i> }
                    </button>
                </div>
                @if (_searchError != null)
                {
                    <div style="font-size:11px;color:var(--red);padding:5px 8px;background:var(--red-bg);border-radius:var(--r);border:1px solid var(--red-border);font-family:var(--font);">
                        <i class="fa-solid fa-triangle-exclamation" style="margin-right:4px;"></i>@_searchError
                    </div>
                }
                <BtnO OnClick="UseCurrentLocationAsync">
                    @if (_isLocating) { <i class="fa-solid fa-spinner fa-spin" style="color:var(--brand);font-size:12px;"></i><span>Obtendo localização...</span> }
                    else              { <i class="fa-solid fa-location-crosshairs" style="color:var(--brand);font-size:12px;"></i><span>Usar minha localização</span> }
                </BtnO>
                @if (_locationError != null)
                {
                    <div style="font-size:11px;color:var(--red);padding:5px 8px;background:var(--red-bg);border-radius:var(--r);border:1px solid var(--red-border);font-family:var(--font);">
                        <i class="fa-solid fa-triangle-exclamation" style="margin-right:4px;"></i>@_locationError
                    </div>
                }
            </div>
        </div>
    </div>

    @* Coluna 2 — Dados básicos *@
    <div class="adicionar-pc-col">
        <div class="adicionar-pc-col-hdr">
            <SecLabel>Dados básicos</SecLabel>
        </div>
        <div class="adicionar-pc-col-body">
            @PcBasicData
        </div>
    </div>

    @* Coluna 3 — Serviços e veículos *@
    <div class="adicionar-pc-col">
        <div class="adicionar-pc-col-hdr">
            <SecLabel>Serviços e veículos</SecLabel>
        </div>
        <div class="adicionar-pc-col-body">
            @PcServices
            @if (_nameError != null)
            {
                <div style="font-size:12px;color:var(--red);padding:8px 12px;background:var(--red-bg);border-radius:var(--r);border:1px solid var(--red-border);font-family:var(--font);">
                    <i class="fa-solid fa-triangle-exclamation" style="margin-right:5px;"></i>@_nameError
                </div>
            }
            @if (_publishError != null)
            {
                <div style="font-size:12px;color:var(--red);padding:8px 12px;background:var(--red-bg);border-radius:var(--r);border:1px solid var(--red-border);font-family:var(--font);">
                    <i class="fa-solid fa-triangle-exclamation" style="margin-right:5px;"></i>@_publishError
                </div>
            }
            <BtnP OnClick="PublishAsync">
                @if (_isPublishing) { <i class="fa-solid fa-spinner fa-spin" style="margin-right:8px;"></i><span>Publicando...</span> }
                else                { <span>Publicar bicicletário</span> }
            </BtnP>
        </div>
    </div>

</div>
}

@* ── Mobile: steps ──────────────────────────────────────────────── *@
else
{
<div class="adicionar-mob-layout">

    <div class="adicionar-mob-hdr">
        <button @onclick="GoBackMobile"
                style="width:34px;height:34px;border-radius:var(--r-full);background:var(--bg-page);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <i class="fa-solid fa-chevron-left" style="color:var(--text-2);font-size:13px;"></i>
        </button>
        <div style="font-size:17px;font-weight:700;color:var(--text);font-family:var(--font);letter-spacing:-0.02em;">@MobileTitle</div>
    </div>

    <div class="adicionar-mob-content">

        @* Mapa: sempre renderizado, oculto fora do step 0 *@
        <div style="@(_mobileStep != 0 ? "display:none" : "")">
            <div style="position:relative;">
                <MapGrid @ref="_map" H="260" />
                <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-100%);pointer-events:none;z-index:400;">
                    <i class="fa-solid fa-location-dot" style="color:var(--brand);font-size:44px;filter:drop-shadow(0 3px 8px rgba(125,17,40,0.45));"></i>
                </div>
                <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:36px;height:36px;border:2px dashed rgba(125,17,40,0.3);border-radius:var(--r-full);margin-top:4px;pointer-events:none;z-index:400;"></div>
            </div>
        </div>

        @* Step 0: busca de endereço *@
        @if (_mobileStep == 0)
        {
            <div style="padding:16px 20px 0;">
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
                    <div style="flex:1;height:1px;background:var(--border);"></div>
                    <span style="font-size:12px;color:var(--text-4);font-family:var(--font);font-weight:500;">ou</span>
                    <div style="flex:1;height:1px;background:var(--border);"></div>
                </div>
                <div style="display:flex;flex-direction:column;gap:10px;">
                    <div style="display:flex;gap:8px;">
                        <div style="flex:1;position:relative;font-family:var(--font);">
                            <i class="fa-solid fa-magnifying-glass" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--text-4);font-size:13px;pointer-events:none;z-index:1;"></i>
                            <input type="text" value="@_searchText"
                                   @oninput="@((e) => _searchText = e.Value?.ToString() ?? "")"
                                   @onkeydown="OnSearchKeyDown"
                                   placeholder="Buscar endereço..."
                                   style="width:100%;border:1.5px solid var(--border);border-radius:var(--r);padding:12px 14px 12px 40px;background:var(--bg);color:var(--text);font-size:15px;font-family:var(--font);line-height:1.4;-webkit-appearance:none;box-sizing:border-box;" />
                        </div>
                        <button @onclick="SearchAddressAsync"
                                style="width:48px;height:48px;border-radius:var(--r);background:var(--brand);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;opacity:@(_isSearching ? "0.6" : "1");">
                            @if (_isSearching) { <i class="fa-solid fa-spinner fa-spin" style="color:white;font-size:14px;"></i> }
                            else               { <i class="fa-solid fa-magnifying-glass" style="color:white;font-size:14px;"></i> }
                        </button>
                    </div>
                    @if (_searchError != null)
                    {
                        <div style="font-size:13px;color:var(--red);font-family:var(--font);padding:8px 12px;background:var(--red-bg);border-radius:var(--r);border:1px solid var(--red-border);">
                            <i class="fa-solid fa-triangle-exclamation" style="margin-right:6px;"></i>@_searchError
                        </div>
                    }
                    <BtnO OnClick="UseCurrentLocationAsync">
                        @if (_isLocating) { <i class="fa-solid fa-spinner fa-spin" style="color:var(--brand);font-size:14px;"></i><span>Obtendo localização...</span> }
                        else              { <i class="fa-solid fa-location-crosshairs" style="color:var(--brand);font-size:14px;"></i><span>Usar minha localização atual</span> }
                    </BtnO>
                    @if (_locationError != null)
                    {
                        <div style="font-size:13px;color:var(--red);font-family:var(--font);padding:8px 12px;background:var(--red-bg);border-radius:var(--r);border:1px solid var(--red-border);">
                            <i class="fa-solid fa-triangle-exclamation" style="margin-right:6px;"></i>@_locationError
                        </div>
                    }
                </div>
            </div>
        }

        @* Step 1: dados básicos *@
        else if (_mobileStep == 1)
        {
            <div style="padding:20px 20px 0;display:flex;flex-direction:column;gap:18px;">
                @MobBasicData
            </div>
        }

        @* Step 2: serviços *@
        else
        {
            <div style="padding:20px 20px 0;display:flex;flex-direction:column;gap:14px;">
                @MobServices
                @if (_publishError != null)
                {
                    <div style="font-size:13px;color:var(--red);padding:10px 14px;background:var(--red-bg);border-radius:var(--r);border:1px solid var(--red-border);font-family:var(--font);">
                        <i class="fa-solid fa-triangle-exclamation" style="margin-right:6px;"></i>@_publishError
                    </div>
                }
            </div>
        }

    </div>

    <div class="adicionar-mob-footer">
        <div style="flex:1;">
            <BtnO OnClick="GoBackMobile">
                <i class="fa-solid fa-chevron-left" style="font-size:12px;"></i> Voltar
            </BtnO>
        </div>
        <div style="flex:1.5;">
            <BtnP OnClick="GoNextMobileAsync">
                @if (_isPublishing)        { <i class="fa-solid fa-spinner fa-spin" style="margin-right:6px;"></i><span>Publicando...</span> }
                else if (_mobileStep == 2) { <span>Publicar bicicletário</span> }
                else                       { <span>Próximo →</span> }
            </BtnP>
        </div>
    </div>

</div>
}

@* ── Render fragments compartilhados ────────────────────────────── *@

@* Dados básicos: fotos, nome, capacidade, acesso, horários *@
@code {
    private RenderFragment PcBasicData =>
    @<div style="display:contents;">

        @* Fotos *@
        <div>
            <label style="display:block;font-size:12px;font-weight:500;color:var(--text-2);margin-bottom:8px;font-family:var(--font);">
                Fotos <span style="color:var(--text-4);font-weight:400;">(opcional · até @MaxFotos)</span>
            </label>
            @if (_fotoPreviews.Count > 0)
            {
                <div style="display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;scrollbar-width:none;">
                    @for (var i = 0; i < _fotoPreviews.Count; i++)
                    {
                        var idx = i;
                        <div style="position:relative;flex-shrink:0;width:72px;height:72px;border-radius:var(--r);overflow:hidden;border:1.5px solid var(--border);">
                            <img src="@_fotoPreviews[idx]" alt="Foto @(idx+1)" style="width:100%;height:100%;object-fit:cover;" />
                            <button type="button" @onclick="@(() => RemoverFoto(idx))"
                                    style="position:absolute;top:3px;right:3px;width:18px;height:18px;border-radius:var(--r-full);background:rgba(0,0,0,0.55);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;-webkit-appearance:none;">
                                <i class="fa-solid fa-xmark" style="color:white;font-size:8px;"></i>
                            </button>
                            @if (idx == 0)
                            {
                                <div style="position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,0.45);text-align:center;font-size:9px;color:white;font-family:var(--font);padding:2px 0;pointer-events:none;">capa</div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="border:1.5px dashed var(--border-2);border-radius:var(--r-lg);height:64px;display:flex;align-items:center;justify-content:center;background:var(--bg-page);">
                    <div style="display:flex;flex-direction:column;align-items:center;gap:4px;color:var(--text-4);">
                        <i class="fa-solid fa-images" style="font-size:16px;"></i>
                        <span style="font-size:11px;font-family:var(--font);">Nenhuma foto</span>
                    </div>
                </div>
            }
            @if (_fotoPreviews.Count < MaxFotos)
            {
                <div style="display:flex;gap:6px;margin-top:7px;">
                    <label for="fotoInputPc" style="flex:1;display:flex;align-items:center;justify-content:center;gap:5px;padding:7px;border:1px solid var(--border);border-radius:var(--r);cursor:pointer;font-size:11px;color:var(--text-2);font-family:var(--font);background:var(--bg-page);">
                        <i class="fa-solid fa-image"></i><span>Galeria</span>
                    </label>
                    <button type="button" @onclick="TirarFotoPc" disabled="@_isCameraLoading"
                            style="flex:1;display:flex;align-items:center;justify-content:center;gap:5px;padding:7px;border:1px solid var(--border);border-radius:var(--r);cursor:pointer;font-size:11px;color:var(--text-2);font-family:var(--font);background:var(--bg-page);">
                        <i class="fa-solid fa-camera"></i><span>@(_isCameraLoading ? "..." : "Câmera")</span>
                    </button>
                </div>
            }
            <InputFile @key="_fotoInputKey" id="fotoInputPc" multiple OnChange="OnFotoSelecionada"
                       accept="image/webp,image/png,image/jpeg,image/heic,image/heif" style="display:none;" />
            <input id="cameraInputPc" type="file" accept="image/*" capture="environment" style="display:none;" />
            @if (_fotoError != null)
            {
                <div style="font-size:11px;color:var(--red);margin-top:4px;font-family:var(--font);">
                    <i class="fa-solid fa-triangle-exclamation" style="margin-right:3px;"></i>@_fotoError
                </div>
            }
        </div>

        @* Nome *@
        <div>
            <label style="display:block;font-size:12px;font-weight:500;color:var(--text-2);margin-bottom:8px;font-family:var(--font);">
                Nome do bicicletário <span style="color:var(--brand);">*</span>
            </label>
            <WfInput Placeholder="Ex: Bicicletário Parque das Flores" Value="@_name" ValueChanged="@((v) => { _name = v; _nameError = null; })" />
        </div>

        @* Capacidade *@
        <div>
            <label style="display:block;font-size:12px;font-weight:500;color:var(--text-2);margin-bottom:8px;font-family:var(--font);">
                Capacidade <span style="color:var(--text-4);font-weight:400;">(vagas)</span>
            </label>
            <WfInput Placeholder="Ex: 20" Type="number" IconClass="fa-hashtag" Value="@_capacity" ValueChanged="@((v) => _capacity = v)" />
        </div>

        @* Tipo de acesso *@
        <div>
            <label style="display:block;font-size:12px;font-weight:500;color:var(--text-2);margin-bottom:10px;font-family:var(--font);">Tipo de acesso</label>
            <div style="display:flex;flex-direction:column;gap:7px;">
                <div @onclick="@(() => _accessType = 0)" style="cursor:pointer;"><RadioItem Checked="@(_accessType == 0)">Livre — sem restrições</RadioItem></div>
                <div @onclick="@(() => _accessType = 1)" style="cursor:pointer;"><RadioItem Checked="@(_accessType == 1)">Pago — tarifa por uso</RadioItem></div>
                <div @onclick="@(() => _accessType = 2)" style="cursor:pointer;"><RadioItem Checked="@(_accessType == 2)">Requer cadastro prévio</RadioItem></div>
                <div @onclick="@(() => _accessType = 3)" style="cursor:pointer;"><RadioItem Checked="@(_accessType == 3)">Mensalidade</RadioItem></div>
            </div>
        </div>

        @* Horários *@
        <div>
            <label style="display:block;font-size:12px;font-weight:500;color:var(--text-2);margin-bottom:10px;font-family:var(--font);">
                Horários <span style="color:var(--text-4);font-weight:400;">(opcional)</span>
            </label>
            <div style="background:var(--bg-page);border:1px solid var(--border);border-radius:var(--r);padding:9px;margin-bottom:9px;">
                <div style="font-size:10px;font-weight:600;color:var(--text-4);font-family:var(--font);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:7px;">Aplicar em grupo</div>
                <div style="display:flex;gap:5px;align-items:center;flex-wrap:wrap;margin-bottom:7px;">
                    <input type="time" value="@_presetAbertura" @oninput="@(e => _presetAbertura = e.Value?.ToString() ?? _presetAbertura)"
                           style="border:1px solid var(--border);border-radius:var(--r);padding:3px 5px;font-family:var(--font);font-size:11px;background:var(--bg);color:var(--text);outline:none;" />
                    <span style="color:var(--text-4);font-size:11px;">–</span>
                    <input type="time" value="@_presetFechamento" @oninput="@(e => _presetFechamento = e.Value?.ToString() ?? _presetFechamento)"
                           style="border:1px solid var(--border);border-radius:var(--r);padding:3px 5px;font-family:var(--font);font-size:11px;background:var(--bg);color:var(--text);outline:none;" />
                </div>
                <div style="display:flex;gap:4px;flex-wrap:wrap;">
                    @foreach (var (label, dias) in _presets)
                    {
                        var d = dias;
                        <button type="button" @onclick="@(() => AplicarPreset(d))" style="@PresetBtnStyle">@label</button>
                    }
                </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:5px;">
                @for (var i = 0; i < 7; i++)
                {
                    var idx = i;
                    var h = _horarios[idx];
                    <div style="display:flex;align-items:center;gap:5px;">
                        <button type="button" @onclick="@(() => { h.Ciclar(); StateHasChanged(); })" style="@HorarioBtnStyle(h.Estado)">
                            @_diasSemana[idx]
                        </button>
                        @if (h.Estado == "aberto")
                        {
                            <input type="time" value="@h.Abertura" @oninput="@(e => { h.Abertura = e.Value?.ToString() ?? h.Abertura; StateHasChanged(); })"
                                   style="flex:1;border:1px solid var(--border);border-radius:var(--r);padding:3px 5px;font-family:var(--font);font-size:11px;background:var(--bg-page);color:var(--text);outline:none;" />
                            <span style="color:var(--text-4);font-size:10px;">–</span>
                            <input type="time" value="@h.Fechamento" @oninput="@(e => { h.Fechamento = e.Value?.ToString() ?? h.Fechamento; StateHasChanged(); })"
                                   style="flex:1;border:1px solid var(--border);border-radius:var(--r);padding:3px 5px;font-family:var(--font);font-size:11px;background:var(--bg-page);color:var(--text);outline:none;" />
                        }
                        else if (h.Estado == "fechado") { <span style="font-size:11px;color:var(--text-3);font-family:var(--font);">Fechado</span> }
                        else                            { <span style="font-size:11px;color:var(--text-4);font-family:var(--font);">—</span> }
                    </div>
                }
            </div>
        </div>

    </div>;

    private RenderFragment PcServices =>
    @<div style="display:contents;">
        <div style="background:var(--bg);border-radius:var(--r-lg);border:1px solid var(--border);padding:14px;">
            <SecLabel>Serviços disponíveis</SecLabel>
            @foreach (var s in _servicos)
            {
                var item = s;
                <div @onclick="() => item.Checked = !item.Checked">
                    <CheckItem Checked="@item.Checked">
                        <div style="display:flex;align-items:center;gap:9px;font-family:var(--font);font-size:13px;color:var(--text-2);">
                            <div style="width:24px;height:24px;border-radius:var(--r-sm);background:var(--bg-page);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="fa-solid @item.Icon" style="color:var(--text-4);font-size:10px;"></i>
                            </div>
                            <span>@item.Label</span>
                        </div>
                    </CheckItem>
                </div>
            }
        </div>
        <div style="background:var(--bg);border-radius:var(--r-lg);border:1px solid var(--border);padding:14px;">
            <SecLabel>Veículos suportados</SecLabel>
            @foreach (var v in _veiculos)
            {
                var item = v;
                <div @onclick="() => item.Checked = !item.Checked">
                    <CheckItem Checked="@item.Checked">
                        <div style="display:flex;align-items:center;gap:9px;font-family:var(--font);font-size:13px;color:var(--text-2);">
                            <div style="width:24px;height:24px;border-radius:var(--r-sm);background:var(--bg-page);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="fa-solid @item.Icon" style="color:var(--text-4);font-size:10px;"></i>
                            </div>
                            <span>@item.Label</span>
                        </div>
                    </CheckItem>
                </div>
            }
        </div>
    </div>;

    private RenderFragment MobBasicData =>
    @<div style="display:contents;">

        @* Fotos (mobile) *@
        <div>
            <label style="display:block;font-size:13px;font-weight:500;color:var(--text-2);margin-bottom:8px;font-family:var(--font);">
