        </div>

        @* Capacidade *@
        <div>
            <label style="display:block;font-size:13px;font-weight:500;color:var(--text-2);margin-bottom:8px;font-family:var(--font);">
                Capacidade <span style="color:var(--text-4);font-weight:400;">(número de vagas)</span>
            </label>
            <WfInput Placeholder="Ex: 20" Type="number" IconClass="fa-hashtag" Value="@_capacity" ValueChanged="@((v) => _capacity = v)" />
        </div>

        @* Tipo de acesso *@
        <div>
            <label style="display:block;font-size:13px;font-weight:500;color:var(--text-2);margin-bottom:10px;font-family:var(--font);">Tipo de acesso</label>
            <div style="display:flex;flex-direction:column;gap:8px;">
                <div @onclick="@(() => _accessType = 0)" style="cursor:pointer;"><RadioItem Checked="@(_accessType == 0)">Livre — sem restrições</RadioItem></div>
                <div @onclick="@(() => _accessType = 1)" style="cursor:pointer;"><RadioItem Checked="@(_accessType == 1)">Pago — tarifa por uso</RadioItem></div>
                <div @onclick="@(() => _accessType = 2)" style="cursor:pointer;"><RadioItem Checked="@(_accessType == 2)">Requer cadastro prévio</RadioItem></div>
                <div @onclick="@(() => _accessType = 3)" style="cursor:pointer;"><RadioItem Checked="@(_accessType == 3)">Mensalidade</RadioItem></div>
            </div>
        </div>

        @* Horários *@
        <div>
            <label style="display:block;font-size:13px;font-weight:500;color:var(--text-2);margin-bottom:10px;font-family:var(--font);">
                Horário de funcionamento <span style="color:var(--text-4);font-weight:400;">(opcional)</span>
            </label>
            <div style="background:var(--bg-page);border:1px solid var(--border);border-radius:var(--r);padding:10px;margin-bottom:10px;">
                <div style="font-size:11px;font-weight:600;color:var(--text-4);font-family:var(--font);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px;">Aplicar em grupo</div>
                <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;margin-bottom:8px;">
                    <input type="time" value="@_presetAbertura" @oninput="@(e => _presetAbertura = e.Value?.ToString() ?? _presetAbertura)"
                           style="border:1px solid var(--border);border-radius:var(--r);padding:4px 8px;font-family:var(--font);font-size:13px;background:var(--bg);color:var(--text);outline:none;" />
                    <span style="color:var(--text-4);font-size:12px;">–</span>
                    <input type="time" value="@_presetFechamento" @oninput="@(e => _presetFechamento = e.Value?.ToString() ?? _presetFechamento)"
                           style="border:1px solid var(--border);border-radius:var(--r);padding:4px 8px;font-family:var(--font);font-size:13px;background:var(--bg);color:var(--text);outline:none;" />
                </div>
                <div style="display:flex;gap:6px;flex-wrap:wrap;">
                    @foreach (var (label, dias) in _presets)
                    {
                        var d = dias;
                        <button type="button" @onclick="@(() => AplicarPreset(d))"
                                style="padding:4px 10px;border-radius:var(--r);border:1px solid var(--border);background:var(--bg);font-family:var(--font);font-size:12px;font-weight:600;color:var(--text-2);cursor:pointer;">
                            @label
                        </button>
                    }
                </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:6px;">
                @for (var i = 0; i < 7; i++)
                {
                    var idx = i;
                    var h = _horarios[idx];
                    <div style="display:flex;align-items:center;gap:8px;">
                        <button type="button" @onclick="@(() => { h.Ciclar(); StateHasChanged(); })" style="@HorarioBtnStyle(h.Estado)">
                            @_diasSemana[idx]
                        </button>
                        @if (h.Estado == "aberto")
                        {
                            <input type="time" value="@h.Abertura" @oninput="@(e => { h.Abertura = e.Value?.ToString() ?? h.Abertura; StateHasChanged(); })"
                                   style="flex:1;border:1px solid var(--border);border-radius:var(--r);padding:4px 8px;font-family:var(--font);font-size:13px;background:var(--bg-page);color:var(--text);outline:none;" />
                            <span style="color:var(--text-4);font-size:12px;">–</span>
                            <input type="time" value="@h.Fechamento" @oninput="@(e => { h.Fechamento = e.Value?.ToString() ?? h.Fechamento; StateHasChanged(); })"
                                   style="flex:1;border:1px solid var(--border);border-radius:var(--r);padding:4px 8px;font-family:var(--font);font-size:13px;background:var(--bg-page);color:var(--text);outline:none;" />
                        }
                        else if (h.Estado == "fechado") { <span style="font-size:12px;color:var(--text-3);font-family:var(--font);">Fechado</span> }
                        else                            { <span style="font-size:12px;color:var(--text-4);font-family:var(--font);">—</span> }
                    </div>
                }
            </div>
        </div>

    </div>;

    private RenderFragment MobServices =>
    @<div style="display:contents;">
        <div style="background:var(--bg);border-radius:var(--r-lg);border:1px solid var(--border);padding:16px;">
            <SecLabel>Serviços disponíveis</SecLabel>
            @foreach (var s in _servicos)
            {
                var item = s;
                <div @onclick="() => item.Checked = !item.Checked">
                    <CheckItem Checked="@item.Checked">
                        <div style="display:flex;align-items:center;gap:10px;font-family:var(--font);font-size:14px;color:var(--text-2);">
                            <div style="width:28px;height:28px;border-radius:var(--r-sm);background:var(--bg-page);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="fa-solid @item.Icon" style="color:var(--text-4);font-size:12px;"></i>
                            </div>
                            <span>@item.Label</span>
                        </div>
                    </CheckItem>
                </div>
            }
        </div>
        <div style="background:var(--bg);border-radius:var(--r-lg);border:1px solid var(--border);padding:16px;">
            <SecLabel>Veículos suportados</SecLabel>
            @foreach (var v in _veiculos)
            {
                var item = v;
                <div @onclick="() => item.Checked = !item.Checked">
                    <CheckItem Checked="@item.Checked">
                        <div style="display:flex;align-items:center;gap:10px;font-family:var(--font);font-size:14px;color:var(--text-2);">
                            <div style="width:28px;height:28px;border-radius:var(--r-sm);background:var(--bg-page);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="fa-solid @item.Icon" style="color:var(--text-4);font-size:12px;"></i>
                            </div>
                            <span>@item.Label</span>
                        </div>
                    </CheckItem>
                </div>
            }
        </div>
    </div>;
}

@code {

    // ── Localização ───────────────────────────────────────────────
    private MapGrid? _map;
    private string   _searchText = "";
    private bool     _isSearching;
    private bool     _isLocating;
    private string?  _searchError;
    private string?  _locationError;

    // ── Dados básicos ─────────────────────────────────────────────
    private string  _name = "";
    private string  _capacity = "";
    private int     _accessType = 0;
    private string? _nameError;

    private List<string>       _fotoPreviews = [];
    private List<FotoParaUpload> _fotos      = [];
    private string? _fotoError;
    private bool    _isCameraLoading;
    private int     _fotoInputKey = 0;
    private const int MaxFotos = 5;

    private static readonly string[] _diasSemana = ["Dom", "Seg", "Ter", "Qua", "Qui", "Sex", "Sáb"];
    private HorarioItem[] _horarios = Enumerable.Range(0, 7).Select(_ => new HorarioItem()).ToArray();
    private string _presetAbertura  = "08:00";
    private string _presetFechamento = "18:00";

    private static readonly (string Label, int[] Dias)[] _presets =
    [
        ("Todos",     new[] { 0,1,2,3,4,5,6 }),
        ("Dias úteis",new[] { 1,2,3,4,5     }),
        ("Seg–Sáb",   new[] { 1,2,3,4,5,6   }),
        ("Sáb",       new[] { 6              }),
        ("Dom",       new[] { 0              }),
    ];

    // ── Serviços ──────────────────────────────────────────────────
    private CheckOption[] _servicos =
    [
        new("fa-plug",     "Tomada elétrica",        true),
        new("fa-gauge",    "Calibrador de pneus",     true),
        new("fa-box",      "Armário / guarda-volume", false),
        new("fa-wrench",   "Espaço de manutenção",    false),
        new("fa-lock",     "Cadeado próprio",         false),
        new("fa-restroom", "Banheiro",                false),
    ];
    private CheckOption[] _veiculos =
    [
        new("fa-bicycle",       "Bicicleta",         true),
        new("fa-person-biking", "Scooter",           false),
        new("fa-bolt",          "Patinete elétrico", false),
        new("fa-circle-dot",    "Monociclo",         false),
    ];
    private string? _publishError;

    // ── UI / Lifecycle ────────────────────────────────────────────
    private bool? _isPc;
    private bool  _isAuthenticated;
    private int   _mobileStep = 0;
    private bool  _isPublishing;

    private string MobileTitle => _mobileStep switch
    {
        0 => "Adicionar bicicletário",
        1 => "Dados básicos",
        _ => "Serviços e veículos"
    };

    protected override async Task OnInitializedAsync()
    {
        _isPc = await JS.InvokeAsync<bool>("matchesMedia", "(min-width: 900px)");
        var user = await AuthService.GetUserInfoAsync();
        _isAuthenticated = user is not null;
    }

    // ── Localização ───────────────────────────────────────────────

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAddressAsync();
    }

    private async Task SearchAddressAsync()
    {
        if (string.IsNullOrWhiteSpace(_searchText) || _isSearching) return;
        _isSearching = true;
        _searchError = null;
        StateHasChanged();
        try
        {
            var client  = HttpFactory.CreateClient("geocoder");
            var results = await client.GetFromJsonAsync<NominatimResult[]>(
                $"search?format=json&q={Uri.EscapeDataString(_searchText)}&limit=1&addressdetails=0");
            if (results?.Length > 0)
            {
                var lat = double.Parse(results[0].Lat, System.Globalization.CultureInfo.InvariantCulture);
                var lng = double.Parse(results[0].Lon, System.Globalization.CultureInfo.InvariantCulture);
                await _map!.PanToAsync(lat, lng);
            }
            else
            {
                _searchError = "Endereço não encontrado. Tente ser mais específico.";
            }
        }
        catch { _searchError = "Erro ao buscar endereço. Verifique sua conexão."; }
        finally { _isSearching = false; StateHasChanged(); }
    }

    private async Task UseCurrentLocationAsync()
    {
        if (_isLocating) return;
        _isLocating = true;
        _locationError = null;
        StateHasChanged();
        try
        {
            var arr = await JS.InvokeAsync<double[]>("mapInterop.getUserLocation");
            await _map!.PanToAsync(arr[0], arr[1]);
            var client = HttpFactory.CreateClient("geocoder");
            var result = await client.GetFromJsonAsync<NominatimReverseResult>(
                $"reverse?format=json&lat={arr[0].ToString(System.Globalization.CultureInfo.InvariantCulture)}&lon={arr[1].ToString(System.Globalization.CultureInfo.InvariantCulture)}");
            if (result?.DisplayName is not null) _searchText = result.DisplayName;
        }
        catch (Exception ex)
        {
            _locationError = ex.Message.Contains("denied") || ex.Message.Contains("ermissão")
                ? "Permissão de localização negada. Verifique as configurações do navegador."
                : "Não foi possível obter sua localização.";
        }
        finally { _isLocating = false; StateHasChanged(); }
    }

    // ── Fotos ─────────────────────────────────────────────────────

    private async Task OnFotoSelecionada(InputFileChangeEventArgs e)
    {
        _fotoError = null;
        const long maxSize = 10L * 1024 * 1024;
        var tiposPermitidos = new[] { "image/webp", "image/png", "image/jpeg", "image/heic", "image/heif" };
        foreach (var file in e.GetMultipleFiles(MaxFotos - _fotoPreviews.Count))
        {
            if (file.Size > maxSize) { _fotoError = "Uma foto deve ter no máximo 10 MB."; continue; }
            var mime = string.IsNullOrWhiteSpace(file.ContentType) ? "image/jpeg" : file.ContentType.ToLowerInvariant();
            if (!tiposPermitidos.Contains(mime)) { _fotoError = "Use PNG, JPG, WEBP ou HEIC."; continue; }
            try
            {
                using var stream = file.OpenReadStream(maxAllowedSize: maxSize);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                await AplicarCompressao(ms.ToArray(), mime);
            }
            catch { _fotoError = "Não foi possível ler o arquivo."; }
        }
        _fotoInputKey++;
    }

    private async Task TirarFotoPc()  => await TirarFotoComId("cameraInputPc");
    private async Task TirarFotoMob() => await TirarFotoComId("cameraInputMob");

    private async Task TirarFotoComId(string inputId)
    {
        _fotoError = null;
        _isCameraLoading = true;
        try
        {
            var json = await JS.InvokeAsync<string?>("imageCompressor.captureAndCompress", inputId, 1200, 0.85);
            if (json is null) return;
            var result = JsonSerializer.Deserialize<CameraResult>(json);
            if (result?.DataUrl is null) return;
            await AplicarDataUrl(result.DataUrl);
        }
        catch { _fotoError = "Não foi possível capturar a foto."; }
        finally { _isCameraLoading = false; }
    }

    private async Task AplicarCompressao(byte[] bytes, string mimeType)
    {
        var dataUrl = await JS.InvokeAsync<string?>("imageCompressor.compress",
            Convert.ToBase64String(bytes), mimeType, 1200, 0.85);
        if (dataUrl is null) { _fotoError = "Não foi possível comprimir a imagem."; return; }
        await AplicarDataUrl(dataUrl);
    }

    private Task AplicarDataUrl(string dataUrl)
    {
        var base64 = dataUrl.Split(',')[1];
        _fotos.Add(new FotoParaUpload { Bytes = Convert.FromBase64String(base64), ContentType = "image/jpeg" });
        _fotoPreviews.Add(dataUrl);
        return Task.CompletedTask;
    }

    private void RemoverFoto(int index)
    {
        _fotos.RemoveAt(index);
        _fotoPreviews.RemoveAt(index);
    }

    // ── Horários ──────────────────────────────────────────────────

    private void AplicarPreset(int[] dias)
    {
        foreach (var d in dias)
        {
            _horarios[d].Estado    = "aberto";
            _horarios[d].Abertura  = _presetAbertura;
            _horarios[d].Fechamento = _presetFechamento;
        }
    }

    private const string PresetBtnStyle =
        "padding:3px 8px;border-radius:var(--r);border:1px solid var(--border);background:var(--bg);font-family:var(--font);font-size:11px;font-weight:600;color:var(--text-2);cursor:pointer;";

    private static string HorarioBtnStyle(string estado) => estado switch
    {
        "aberto"  => "width:40px;font-size:11px;font-weight:600;padding:3px 6px;border-radius:var(--r);border:1px solid var(--brand);background:var(--brand-soft);color:var(--brand);cursor:pointer;font-family:var(--font);flex-shrink:0;",
        "fechado" => "width:40px;font-size:11px;font-weight:600;padding:3px 6px;border-radius:var(--r);border:1px solid var(--border);background:var(--bg-page);color:var(--text-3);cursor:pointer;font-family:var(--font);flex-shrink:0;text-decoration:line-through;",
        _         => "width:40px;font-size:11px;font-weight:600;padding:3px 6px;border-radius:var(--r);border:1px dashed var(--border-2);background:var(--bg-page);color:var(--text-4);cursor:pointer;font-family:var(--font);flex-shrink:0;",
    };

    // ── Navegação mobile ──────────────────────────────────────────

    private async Task GoNextMobileAsync()
    {
        if (_mobileStep == 0)
        {
            if (await _map!.GetCenterAsync() is null) return;
            _mobileStep = 1;
        }
        else if (_mobileStep == 1)
        {
            if (string.IsNullOrWhiteSpace(_name))
            {
                _nameError = "O nome do bicicletário é obrigatório.";
                return;
            }
            _mobileStep = 2;
        }
        else
        {
            await PublishAsync();
        }
    }

    private void GoBackMobile()
    {
        if (_mobileStep == 0) Nav.NavigateTo("/");
        else _mobileStep--;
    }

    // ── Publicar ──────────────────────────────────────────────────

    private async Task PublishAsync()
    {
        _nameError     = null;
        _publishError  = null;

        if (string.IsNullOrWhiteSpace(_name))
        {
            _nameError = "O nome do bicicletário é obrigatório.";
            return;
        }

        var center = await _map!.GetCenterAsync();
        if (center is null) return;

        _isPublishing = true;
        StateHasChanged();
        try
        {
            var (error, id) = await BicicletarioSvc.CreateAsync(BuildRequest(center.Value.Lat, center.Value.Lng));
            if (error != null) { _publishError = error; return; }

            if (_fotos.Count > 0 && id is not null)
            {
                foreach (var foto in _fotos)
                {
                    using var ms      = new MemoryStream(foto.Bytes);
                    using var content = new MultipartFormDataContent();
                    var fileContent   = new StreamContent(ms);
                    fileContent.Headers.ContentType = new MediaTypeHeaderValue(foto.ContentType);
                    var ext = foto.ContentType switch { "image/webp" => ".webp", "image/png" => ".png", _ => ".jpg" };
                    content.Add(fileContent, "foto", $"foto{ext}");
                    await BicicletarioSvc.UploadFotoAsync(id, content);
                }
            }

            ToastSvc.Show("Bicicletário publicado com sucesso!");
            Nav.NavigateTo("/", forceLoad: false);
        }
        finally { _isPublishing = false; StateHasChanged(); }
    }

    private CreateBicicletarioRequest BuildRequest(double lat, double lng)
    {
        var hs = _horarios
            .Select((h, i) => h.Estado == "aberto"
                ? new HorarioModel { DiaSemana = i, HoraAbertura = h.Abertura, HoraFechamento = h.Fechamento }
                : null)
            .Where(h => h != null).Select(h => h!).ToArray();

        return new CreateBicicletarioRequest
        {
            Nome                = _name.Trim(),
            Latitude            = lat,
            Longitude           = lng,
            TemTomada           = _servicos[0].Checked,
            TemCalibrador       = _servicos[1].Checked,
            TemArmario          = _servicos[2].Checked,
            TemEspacoManutencao = _servicos[3].Checked,
            TemCadeado          = _servicos[4].Checked,
            TemBanheiro         = _servicos[5].Checked,
            TemVestiario        = false,
            AcessoLivre         = _accessType == 0,
            AcessoPago          = _accessType == 1,
            AcessoCadastro      = _accessType == 2,
            AcessoMensal        = _accessType == 3,
            VeiculosSuportados  = (_veiculos[0].Checked ? 1 : 0)
                                | (_veiculos[1].Checked ? 2 : 0)
                                | (_veiculos[2].Checked ? 8 : 0)
                                | (_veiculos[3].Checked ? 4 : 0),
            Horarios            = hs.Length > 0 ? hs : null,
        };
    }

    // ── Inner types ───────────────────────────────────────────────

    private class HorarioItem
    {
        public string Estado    = "ni";
        public string Abertura  = "08:00";
        public string Fechamento = "18:00";
        public void Ciclar() => Estado = Estado switch { "ni" => "aberto", "aberto" => "fechado", _ => "ni" };
    }

    private class CheckOption(string icon, string label, bool @checked)
    {
        public string Icon    { get; } = icon;
        public string Label   { get; } = label;
        public bool   Checked { get; set; } = @checked;
    }

    private class NominatimResult
    {
        public string Lat { get; set; } = "";
        public string Lon { get; set; } = "";
    }

    private class NominatimReverseResult
    {
        [JsonPropertyName("display_name")]
        public string? DisplayName { get; set; }
    }

    private record CameraResult([property: JsonPropertyName("dataUrl")] string? DataUrl);
}
