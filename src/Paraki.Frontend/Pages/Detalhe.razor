    private void HandleTouchStart(TouchEventArgs e)
    {
        if (e.Touches.Length > 0)
        {
            _touchStartX = e.Touches[0].ClientX;
            _touchStartY = e.Touches[0].ClientY;
        }
    }

    private void HandleTouchEnd(TouchEventArgs e)
    {
        if (e.ChangedTouches.Length == 0 || _fotos.Count <= 1) return;
        var dx = e.ChangedTouches[0].ClientX - _touchStartX;
        var dy = e.ChangedTouches[0].ClientY - _touchStartY;
        if (Math.Abs(dx) <= Math.Abs(dy) || Math.Abs(dx) < 40) return;
        if (dx < 0 && _carouselIndex < _fotos.Count - 1)
            _carouselIndex++;
        else if (dx > 0 && _carouselIndex > 0)
            _carouselIndex--;
    }

    private async Task CarregarFotosAsync()
    {
        var fotos = await BicicletarioSvc.GetFotosAsync(Id!);
        if (fotos != null)
            _fotos = [.. fotos.OrderByDescending(f => f.IsCapa).ThenBy(f => f.Ordem)];
        else
            _legacyCoverUrl = BicicletarioSvc.GetFotoBicicletarioUrl(Id!);
        _carouselIndex = 0;
        StateHasChanged();
    }

    private async Task HandleFotoUpload(InputFileChangeEventArgs e)
    {
        const long maxSize = 10L * 1024 * 1024;
        var tiposPermitidos = new[] { "image/webp", "image/png", "image/jpeg", "image/heic", "image/heif" };

        _isSaving  = true;
        _saveError = null;
        try
        {
            var files = e.GetMultipleFiles(10);
            foreach (var file in files)
            {
                if (file.Size > maxSize) { _saveError = "Uma foto deve ter no máximo 10 MB."; continue; }
                var mimeType = string.IsNullOrWhiteSpace(file.ContentType) ? "image/jpeg" : file.ContentType.ToLowerInvariant();
                if (!tiposPermitidos.Contains(mimeType)) { _saveError = "Use PNG, JPG, WEBP ou HEIC."; continue; }
                try
                {
                    using var readStream = file.OpenReadStream(maxSize);
                    using var ms = new MemoryStream();
                    await readStream.CopyToAsync(ms);
                    var base64 = Convert.ToBase64String(ms.ToArray());
                    var dataUrl = await JS.InvokeAsync<string?>("imageCompressor.compress", base64, mimeType, 1200, 0.85);
                    if (dataUrl is null) { _saveError = "Não foi possível comprimir a imagem."; continue; }
                    await EnviarFotoDataUrl(dataUrl);
                }
                catch { _saveError = "Não foi possível ler o arquivo."; }
            }
        }
        finally
        {
            _isSaving = false;
            _fotoUploadKey++;
            if (_saveError == null) _editingFoto = false;
        }
    }

    private async Task TirarFotoDetalhe()
    {
        _saveError = null;
        _isSaving  = true;
        try
        {
            var json = await JS.InvokeAsync<string?>("imageCompressor.captureAndCompress", "cameraInputDetalhe", 1200, 0.85);
            if (json is null) return;
            var result = JsonSerializer.Deserialize<DetalheCamera>(json);
            if (result?.DataUrl is null) return;
            await EnviarFotoDataUrl(result.DataUrl);
        }
        catch
        {
            _saveError = "Não foi possível capturar a foto.";
        }
        finally
        {
            _isSaving = false;
            _editingFoto = false;
        }
    }

    private async Task EnviarFotoDataUrl(string dataUrl)
    {
        var compressedBytes = Convert.FromBase64String(dataUrl.Split(',')[1]);
        using var content   = new MultipartFormDataContent();
        using var bc        = new ByteArrayContent(compressedBytes);
        bc.Headers.ContentType = new MediaTypeHeaderValue("image/jpeg");
        content.Add(bc, "foto", "foto.jpg");
        var (err, novaFoto) = await BicicletarioSvc.UploadFotoAsync(Id!, content);
        if (err == null && novaFoto != null)
            _fotos.Add(novaFoto);
        else
            _saveError = err;
    }

    private record DetalheCamera([property: JsonPropertyName("dataUrl")] string? DataUrl);

    private async Task SetCapaAsync(string fotoId)
    {
        var err = await BicicletarioSvc.SetCapaAsync(fotoId);
        if (err == null)
        {
            foreach (var f in _fotos) f.IsCapa = (f.Id == fotoId);
            _fotos = [.. _fotos.OrderByDescending(f => f.IsCapa).ThenBy(f => f.Ordem)];
            _carouselIndex = 0;
            StateHasChanged();
        }
        else _saveError = err;
    }

    private async Task DeleteFotoAsync(string fotoId)
    {
        var err = await BicicletarioSvc.DeleteFotoAsync(fotoId);
        if (err == null)
        {
            var removed = _fotos.FirstOrDefault(f => f.Id == fotoId);
            _fotos.Remove(removed!);
            if (removed?.IsCapa == true && _fotos.Count > 0)
                _fotos[0].IsCapa = true;
            if (_carouselIndex >= _fotos.Count)
                _carouselIndex = Math.Max(0, _fotos.Count - 1);
            StateHasChanged();
        }
        else _saveError = err;
    }

