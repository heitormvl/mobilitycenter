@page "/admin"
@inject NavigationManager Nav
@inject AuthService AuthSvc
@inject SugestaoService SugestaoSvc
@inject BicicletarioService BicicletarioSvc
@inject AdminService AdminSvc

<!-- Header -->
<div style="background:var(--bg); padding:0 20px 0; border-bottom:1px solid var(--border); position:sticky; top:0; z-index:20;">
    <StatusBar />
    <div style="display:flex; align-items:center; gap:10px; padding-bottom:0;">
        <i class="fa-solid fa-shield-halved" style="font-size:18px; color:var(--brand);"></i>
        <span style="font-size:17px; font-weight:700; color:var(--text); font-family:var(--font); letter-spacing:-0.02em; flex:1;">Painel Admin</span>
    </div>

    <!-- Tabs mobile (scroll horizontal) -->
    <div style="display:flex; gap:0; overflow-x:auto; -webkit-overflow-scrolling:touch; scrollbar-width:none; margin-top:12px;">
        <button @onclick='@(() => _tab = 0)'
                style="flex-shrink:0; padding:10px 16px; border:none; border-bottom:2px solid @(_tab == 0 ? "var(--brand)" : "transparent"); background:transparent; font-family:var(--font); font-size:14px; font-weight:@(_tab == 0 ? "700" : "500"); color:@(_tab == 0 ? "var(--brand)" : "var(--text-3)"); cursor:pointer; white-space:nowrap; display:flex; align-items:center; gap:6px;">
            <i class="fa-solid fa-pen-to-square" style="font-size:12px;"></i>
            Sugestões
            @if (_contagemSugestoes > 0)
            {
                <span style="background:#DC2626; color:white; font-size:10px; font-weight:700; border-radius:var(--r-full); padding:1px 6px;">@(_contagemSugestoes > 99 ? "99+" : _contagemSugestoes.ToString())</span>
            }
        </button>
        <button @onclick='@(() => _tab = 1)'
                style="flex-shrink:0; padding:10px 16px; border:none; border-bottom:2px solid @(_tab == 1 ? "var(--brand)" : "transparent"); background:transparent; font-family:var(--font); font-size:14px; font-weight:@(_tab == 1 ? "700" : "500"); color:@(_tab == 1 ? "var(--brand)" : "var(--text-3)"); cursor:pointer; white-space:nowrap; display:flex; align-items:center; gap:6px;">
            <i class="fa-solid fa-location-dot" style="font-size:12px;"></i>
            Novos bicicletários
            @if (_contagemBicis > 0)
            {
                <span style="background:#DC2626; color:white; font-size:10px; font-weight:700; border-radius:var(--r-full); padding:1px 6px;">@(_contagemBicis > 99 ? "99+" : _contagemBicis.ToString())</span>
            }
        </button>
    </div>
</div>

<!-- Tab content -->
<div style="padding:16px 16px 88px; display:flex; flex-direction:column; gap:10px; overflow-y:auto;">

    @if (_isLoading)
    {
        @for (int i = 0; i < 3; i++)
        {
            <div style="background:var(--bg); border-radius:var(--r-lg); padding:16px; border:1px solid var(--border);">
                <div style="height:14px; width:55%; background:var(--border); border-radius:4px; margin-bottom:10px;"></div>
                <div style="height:12px; width:35%; background:var(--border); border-radius:4px; margin-bottom:8px;"></div>
                <div style="height:12px; width:45%; background:var(--border); border-radius:4px;"></div>
            </div>
        }
    }
    else if (_loadError != null)
    {
        <div style="text-align:center; padding:40px 20px; font-family:var(--font);">
            <i class="fa-solid fa-triangle-exclamation" style="font-size:32px; color:var(--text-4); margin-bottom:12px; display:block;"></i>
            <div style="font-size:15px; color:var(--text-3);">@_loadError</div>
        </div>
    }
    else if (_tab == 0)
    {
        <!-- Sugestões tab -->
        @if (_pendentes == null || _pendentes.Length == 0)
        {
            <div style="text-align:center; padding:60px 20px; font-family:var(--font);">
                <i class="fa-solid fa-inbox" style="font-size:40px; color:var(--text-4); margin-bottom:14px; display:block;"></i>
                <div style="font-size:16px; font-weight:600; color:var(--text); margin-bottom:6px;">Nenhuma sugestão pendente</div>
                <div style="font-size:14px; color:var(--text-3);">Tudo em dia!</div>
            </div>
        }
        else
        {
            @foreach (var s in _pendentes)
            {
                var sid = s.Id;
                var secoesAlteradas = GetSecoesAlteradas(s.DadosEdicao);
                <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid var(--border); padding:14px 16px; box-shadow:var(--shadow-sm);">
                    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:10px;">
                        <div style="flex:1; min-width:0;">
                            <div style="display:flex; align-items:center; gap:6px; margin-bottom:3px;">
                                <div style="font-size:15px; font-weight:700; color:var(--text); font-family:var(--font); letter-spacing:-0.01em; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@s.NomeBicicletario</div>
                                @if (s.AplicadaAutomaticamente)
                                {
                                    <span style="font-size:9px; font-weight:700; background:#DBEAFE; color:#1D4ED8; padding:2px 6px; border-radius:var(--r-full); font-family:var(--font); letter-spacing:.04em; flex-shrink:0;">AUTO</span>
                                }
                            </div>
                            <div style="font-size:12px; color:var(--brand); font-family:var(--font); font-weight:600; margin-bottom:4px;">@secoesAlteradas</div>
                            <div style="font-size:12px; color:var(--text-4); font-family:var(--font);">
                                <i class="fa-solid fa-user" style="font-size:10px; margin-right:4px;"></i>@s.NomeAutor
                                @if (s.TierAutor == 1) { <span style="margin-left:4px; font-size:9px; font-weight:700; background:#E5E7EB; color:#374151; padding:1px 5px; border-radius:var(--r-full);">PRATA</span> }
                                else if (s.TierAutor == 2) { <span style="margin-left:4px; font-size:9px; font-weight:700; background:#FEF3C7; color:#92400E; padding:1px 5px; border-radius:var(--r-full);">OURO</span> }
                                &nbsp;·&nbsp;@FormatDate(s.CriadoEm)
                            </div>
                        </div>
                        <button @onclick="@(() => AbrirModalSugestao(s))"
                                style="flex-shrink:0; padding:7px 14px; border-radius:var(--r-full); background:var(--brand); border:none; cursor:pointer; font-family:var(--font); font-size:12px; font-weight:700; color:white; white-space:nowrap;">
                            Revisar →
                        </button>
                    </div>
                </div>
            }
        }
    }
    else
    {
        <!-- Novos bicicletários tab -->
        @if (_pendentesB == null || _pendentesB.Length == 0)
        {
            <div style="text-align:center; padding:60px 20px; font-family:var(--font);">
                <i class="fa-solid fa-location-dot" style="font-size:40px; color:var(--text-4); margin-bottom:14px; display:block;"></i>
                <div style="font-size:16px; font-weight:600; color:var(--text); margin-bottom:6px;">Nenhum bicicletário pendente</div>
                <div style="font-size:14px; color:var(--text-3);">Tudo em dia!</div>
            </div>
        }
        else
        {
            @foreach (var b in _pendentesB)
            {
                var bId = b.Id;
                <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid var(--border); padding:14px 16px; box-shadow:var(--shadow-sm);">
                    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:10px;">
                        <div style="flex:1; min-width:0;">
                            <div style="display:flex; align-items:center; gap:6px; margin-bottom:3px;">
                                <div style="font-size:15px; font-weight:700; color:var(--text); font-family:var(--font); letter-spacing:-0.01em; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@b.Nome</div>
                                @if (b.StatusAprovacao == 2)
                                {
                                    <span style="font-size:9px; font-weight:700; background:#DBEAFE; color:#1D4ED8; padding:2px 6px; border-radius:var(--r-full); font-family:var(--font); letter-spacing:.04em; flex-shrink:0;">AUTO</span>
                                }
                                else
                                {
                                    <span style="font-size:9px; font-weight:700; background:#FEF3C7; color:#92400E; padding:2px 6px; border-radius:var(--r-full); font-family:var(--font); letter-spacing:.04em; flex-shrink:0;">PENDENTE</span>
                                }
                            </div>
                            <div style="font-size:12px; color:var(--text-4); font-family:var(--font);">
                                <i class="fa-solid fa-user" style="font-size:10px; margin-right:4px;"></i>@(b.NomeCriador ?? "—")
                                @if (b.TierCriador == 1) { <span style="margin-left:4px; font-size:9px; font-weight:700; background:#E5E7EB; color:#374151; padding:1px 5px; border-radius:var(--r-full);">PRATA</span> }
                                else if (b.TierCriador == 2) { <span style="margin-left:4px; font-size:9px; font-weight:700; background:#FEF3C7; color:#92400E; padding:1px 5px; border-radius:var(--r-full);">OURO</span> }
                                &nbsp;·&nbsp;@FormatDate(b.CriadoEm)
                            </div>
                        </div>
                        <button @onclick="@(() => AbrirModalBicicletario(b))"
                                style="flex-shrink:0; padding:7px 14px; border-radius:var(--r-full); background:var(--brand); border:none; cursor:pointer; font-family:var(--font); font-size:12px; font-weight:700; color:white; white-space:nowrap;">
                            Revisar →
                        </button>
                    </div>
                </div>
            }
        }
    }
</div>

<!-- Modal: revisar sugestão de edição -->
@if (_modalSugestao != null)
{
    <div @onclick="FecharModalSugestao"
         style="position:fixed; inset:0; z-index:900; background:rgba(0,0,0,0.55); display:flex; align-items:flex-end; justify-content:center; padding:0;">
        <div @onclick:stopPropagation="true"
             style="background:var(--bg); border-radius:var(--r-lg) var(--r-lg) 0 0; width:100%; max-width:560px; max-height:92dvh; overflow-y:auto; padding:20px 20px 32px; animation:slideUp .2s ease-out;">

            <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px;">
                <div style="flex:1; min-width:0;">
                    <div style="font-size:16px; font-weight:700; color:var(--text); font-family:var(--font); letter-spacing:-0.01em; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@_modalSugestao.NomeBicicletario</div>
                    <div style="font-size:11px; color:var(--text-4); font-family:var(--font); margin-top:2px;">
                        <i class="fa-solid fa-user" style="font-size:10px; margin-right:4px;"></i>@_modalSugestao.NomeAutor
                        &nbsp;·&nbsp;@_modalSugestao.CriadoEm.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                    </div>
                </div>
                @if (_modalSugestao.AplicadaAutomaticamente)
                {
                    <span style="font-size:10px; font-weight:700; background:#DBEAFE; color:#1D4ED8; padding:3px 8px; border-radius:var(--r-full); font-family:var(--font); letter-spacing:.04em; flex-shrink:0;">AUTO</span>
                }
                else
                {
                    <span style="font-size:10px; font-weight:700; background:#FEF3C7; color:#92400E; padding:3px 8px; border-radius:var(--r-full); font-family:var(--font); letter-spacing:.04em; flex-shrink:0;">PENDENTE</span>
                }
                <button @onclick="FecharModalSugestao"
                        style="width:32px; height:32px; border-radius:var(--r-full); background:var(--bg-page); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fa-solid fa-xmark" style="font-size:13px; color:var(--text-3);"></i>
                </button>
            </div>

            @if (_modalSugestao.AplicadaAutomaticamente)
            {
                <div style="background:#EFF6FF; border:1px solid #BFDBFE; border-radius:var(--r); padding:10px 14px; margin-bottom:16px; font-size:13px; color:#1D4ED8; font-family:var(--font);">
                    <i class="fa-solid fa-circle-info" style="margin-right:6px;"></i>
                    Esta edição já foi aplicada automaticamente (usuário Prata). Rejeitar irá revertê-la.
                </div>
            }

            @if (!string.IsNullOrEmpty(_modalSugestao.Comprovante) || !string.IsNullOrEmpty(_modalSugestao.ComprovanteFotoKey))
            {
                <div style="background:var(--bg-page); border:1px solid var(--border); border-radius:var(--r); padding:12px 14px; margin-bottom:16px;">
                    <div style="font-size:10px; font-weight:700; color:var(--text-4); font-family:var(--font); text-transform:uppercase; letter-spacing:.07em; margin-bottom:8px;">
                        <i class="fa-solid fa-paperclip" style="margin-right:5px;"></i>Comprovante
                    </div>
                    @if (!string.IsNullOrEmpty(_modalSugestao.ComprovanteFotoKey))
                    {
                        var fotoUrl = SugestaoSvc.GetComprovanteUrl(_modalSugestao.Id, _modalSugestao.ComprovanteFotoKey);
                        <img src="@fotoUrl" style="max-width:100%; max-height:240px; object-fit:contain; border-radius:var(--r); display:block; margin-bottom:@(!string.IsNullOrEmpty(_modalSugestao.Comprovante) ? "10px" : "0");" alt="Comprovante" />
                    }
                    @if (!string.IsNullOrEmpty(_modalSugestao.Comprovante))
                    {
                        <p style="font-size:13px; color:var(--text-2); font-family:var(--font); line-height:1.5; margin:0;">@_modalSugestao.Comprovante</p>
                    }
                </div>
            }

            @if (_modalAtualB != null)
            {
                var d = _modalSugestao.DadosEdicao;
                @if (d.TemTomada.HasValue || d.TemCalibrador.HasValue || d.TemVestiario.HasValue ||
                     d.TemArmario.HasValue || d.TemEspacoManutencao.HasValue || d.TemCadeado.HasValue || d.TemBanheiro.HasValue)
                {
                    <div style="margin-bottom:14px;">
                        <div style="font-size:10px; font-weight:700; color:var(--text-4); font-family:var(--font); text-transform:uppercase; letter-spacing:.07em; margin-bottom:8px;">Serviços</div>
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px 16px;">
                            @RenderServico("fa-plug", "Tomada", _modalAtualB.TemTomada, d.TemTomada)
                            @RenderServico("fa-gauge", "Calibrador", _modalAtualB.TemCalibrador, d.TemCalibrador)
                            @RenderServico("fa-shirt", "Vestiário", _modalAtualB.TemVestiario, d.TemVestiario)
                            @RenderServico("fa-box", "Armário", _modalAtualB.TemArmario, d.TemArmario)
                            @RenderServico("fa-wrench", "Manutenção", _modalAtualB.TemEspacoManutencao, d.TemEspacoManutencao)
                            @RenderServico("fa-lock", "Cadeado", _modalAtualB.TemCadeado, d.TemCadeado)
                            @RenderServico("fa-restroom", "Banheiro", _modalAtualB.TemBanheiro, d.TemBanheiro)
                        </div>
                    </div>
                }
                @if (d.AcessoLivre.HasValue || d.AcessoPago.HasValue || d.AcessoCadastro.HasValue || d.AcessoMensal.HasValue)
                {
                    var atualAcesso = _modalAtualB.AcessoLivre ? "Livre" : _modalAtualB.AcessoPago ? "Pago" : _modalAtualB.AcessoCadastro ? "Cadastro" : _modalAtualB.AcessoMensal ? "Mensal" : "—";
                    var novoAcesso  = (d.AcessoLivre == true) ? "Livre" : (d.AcessoPago == true) ? "Pago" : (d.AcessoCadastro == true) ? "Cadastro" : (d.AcessoMensal == true) ? "Mensal" : "—";
                    <div style="margin-bottom:14px;">
                        <div style="font-size:10px; font-weight:700; color:var(--text-4); font-family:var(--font); text-transform:uppercase; letter-spacing:.07em; margin-bottom:8px;">Acesso</div>
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px;">
                            <div style="background:var(--bg-page); border-radius:var(--r); padding:8px 10px;">
                                <div style="font-size:10px; color:var(--text-4); font-family:var(--font); margin-bottom:3px;">Atual</div>
                                <div style="font-size:13px; font-weight:600; color:var(--text-2); font-family:var(--font);">@atualAcesso</div>
                            </div>
                            <div style="background:#EFF6FF; border:1px solid #BFDBFE; border-radius:var(--r); padding:8px 10px;">
                                <div style="font-size:10px; color:#3B82F6; font-family:var(--font); margin-bottom:3px;">Sugerido</div>
                                <div style="font-size:13px; font-weight:600; color:#1D4ED8; font-family:var(--font);">@novoAcesso</div>
                            </div>
                        </div>
                    </div>
                }
                @if (d.VeiculosSuportados.HasValue)
                {
                    <div style="margin-bottom:14px;">
                        <div style="font-size:10px; font-weight:700; color:var(--text-4); font-family:var(--font); text-transform:uppercase; letter-spacing:.07em; margin-bottom:8px;">Veículos</div>
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px;">
                            <div style="background:var(--bg-page); border-radius:var(--r); padding:8px 10px;">
                                <div style="font-size:10px; color:var(--text-4); font-family:var(--font); margin-bottom:3px;">Atual</div>
                                <div style="font-size:13px; font-weight:600; color:var(--text-2); font-family:var(--font);">@VeiculoLabel(_modalAtualB.VeiculosSuportados)</div>
                            </div>
                            <div style="background:#EFF6FF; border:1px solid #BFDBFE; border-radius:var(--r); padding:8px 10px;">
                                <div style="font-size:10px; color:#3B82F6; font-family:var(--font); margin-bottom:3px;">Sugerido</div>
                                <div style="font-size:13px; font-weight:600; color:#1D4ED8; font-family:var(--font);">@VeiculoLabel(d.VeiculosSuportados.Value)</div>
                            </div>
                        </div>
                    </div>
                }
            }
            else if (_modalCarregandoB)
            {
                <div style="padding:20px; text-align:center; font-size:13px; color:var(--text-4); font-family:var(--font);">Carregando dados atuais...</div>
            }

            @if (_rejeitandoS)
            {
                <div style="background:#FEF3C7; border:1px solid #FDE68A; border-radius:var(--r); padding:12px 14px; margin-bottom:12px;">
                    <div style="font-size:12px; font-weight:600; color:#92400E; font-family:var(--font); margin-bottom:8px;">Motivo da rejeição (opcional)</div>
                    <textarea @bind="_motivoS" placeholder="Ex: informação incorreta..."
                              style="width:100%; box-sizing:border-box; border:1px solid #FDE68A; border-radius:var(--r); padding:8px 10px; font-family:var(--font); font-size:13px; color:var(--text); background:var(--bg); outline:none; resize:vertical; min-height:64px;" />
                </div>
            }

            @if (!string.IsNullOrEmpty(_erroS))
            {
                <div style="font-size:12px; color:#DC2626; margin-bottom:12px; font-family:var(--font);">@_erroS</div>
            }

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:8px;">
                <button @onclick="AprovarSugestao" disabled="@_savingS"
                        style="padding:12px; border-radius:var(--r-lg); border:none; background:@(_savingS ? "var(--border)" : "#16A34A"); color:white; font-family:var(--font); font-size:14px; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:6px;">
                    <i class="fa-solid fa-check" style="font-size:12px;"></i>@(_savingS ? "..." : "Aprovar")
                </button>
                @if (!_rejeitandoS)
                {
                    <button @onclick="@(() => _rejeitandoS = true)" disabled="@_savingS"
                            style="padding:12px; border-radius:var(--r-lg); border:1px solid #F59E0B; background:#FEF3C7; color:#92400E; font-family:var(--font); font-size:14px; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:6px;">
                        <i class="fa-solid fa-xmark" style="font-size:12px;"></i>Rejeitar
                    </button>
                }
                else
                {
                    <button @onclick="RejeitarSugestao" disabled="@_savingS"
                            style="padding:12px; border-radius:var(--r-lg); border:none; background:#F59E0B; color:white; font-family:var(--font); font-size:14px; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:6px;">
                        <i class="fa-solid fa-xmark" style="font-size:12px;"></i>Confirmar rejeição
                    </button>
                }
            </div>
        </div>
    </div>
}

<!-- Modal: revisar bicicletário pendente -->
@if (_modalBicicletario != null)
{
    <div @onclick="FecharModalBicicletario"
         style="position:fixed; inset:0; z-index:900; background:rgba(0,0,0,0.55); display:flex; align-items:flex-end; justify-content:center; padding:0;">
        <div @onclick:stopPropagation="true"
             style="background:var(--bg); border-radius:var(--r-lg) var(--r-lg) 0 0; width:100%; max-width:560px; max-height:92dvh; overflow-y:auto; padding:20px 20px 32px; animation:slideUp .2s ease-out;">

            <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px;">
                <div style="flex:1; min-width:0;">
                    <div style="font-size:16px; font-weight:700; color:var(--text); font-family:var(--font); letter-spacing:-0.01em;">@_modalBicicletario.Nome</div>
                    <div style="font-size:11px; color:var(--text-4); font-family:var(--font); margin-top:2px;">
                        <i class="fa-solid fa-user" style="font-size:10px; margin-right:4px;"></i>@(_modalBicicletario.NomeCriador ?? "—")
                        &nbsp;·&nbsp;@_modalBicicletario.CriadoEm.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                    </div>
                </div>
                @if (_modalBicicletario.StatusAprovacao == 2)
                {
                    <span style="font-size:10px; font-weight:700; background:#DBEAFE; color:#1D4ED8; padding:3px 8px; border-radius:var(--r-full); font-family:var(--font); letter-spacing:.04em; flex-shrink:0;">AUTO</span>
                }
                else
                {
                    <span style="font-size:10px; font-weight:700; background:#FEF3C7; color:#92400E; padding:3px 8px; border-radius:var(--r-full); font-family:var(--font); letter-spacing:.04em; flex-shrink:0;">PENDENTE</span>
                }
                <button @onclick="FecharModalBicicletario"
                        style="width:32px; height:32px; border-radius:var(--r-full); background:var(--bg-page); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fa-solid fa-xmark" style="font-size:13px; color:var(--text-3);"></i>
                </button>
            </div>

            @if (_modalBicicletario.StatusAprovacao == 2)
            {
                <div style="background:#DBEAFE; border:1px solid #BFDBFE; border-radius:var(--r); padding:10px 14px; margin-bottom:16px; font-size:13px; color:#1D4ED8; font-family:var(--font);">
                    <i class="fa-solid fa-circle-info" style="margin-right:6px;"></i>
                    Já publicado automaticamente (usuário Prata). Rejeitar vai ocultar este bicicletário.
                </div>
            }

            <!-- Detalhes do bicicletário -->
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:14px;">
                <div style="background:var(--bg-page); border-radius:var(--r); padding:10px 12px;">
                    <div style="font-size:10px; color:var(--text-4); font-family:var(--font); margin-bottom:4px; text-transform:uppercase; letter-spacing:.05em;">Acesso</div>
                    <div style="font-size:13px; font-weight:600; color:var(--text-2); font-family:var(--font);">
                        @(_modalBicicletario.AcessoLivre ? "Livre" : _modalBicicletario.AcessoPago ? "Pago" : _modalBicicletario.AcessoCadastro ? "Cadastro" : _modalBicicletario.AcessoMensal ? "Mensal" : "—")
                    </div>
                </div>
                <div style="background:var(--bg-page); border-radius:var(--r); padding:10px 12px;">
                    <div style="font-size:10px; color:var(--text-4); font-family:var(--font); margin-bottom:4px; text-transform:uppercase; letter-spacing:.05em;">Veículos</div>
                    <div style="font-size:13px; font-weight:600; color:var(--text-2); font-family:var(--font);">@VeiculoLabel(_modalBicicletario.VeiculosSuportados)</div>
                </div>
            </div>

            <!-- Serviços -->
            <div style="background:var(--bg-page); border-radius:var(--r); padding:10px 12px; margin-bottom:14px;">
                <div style="font-size:10px; color:var(--text-4); font-family:var(--font); text-transform:uppercase; letter-spacing:.05em; margin-bottom:8px;">Serviços</div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:4px;">
                    @RenderServicoSimples("fa-plug", "Tomada", _modalBicicletario.TemTomada)
                    @RenderServicoSimples("fa-gauge", "Calibrador", _modalBicicletario.TemCalibrador)
                    @RenderServicoSimples("fa-shirt", "Vestiário", _modalBicicletario.TemVestiario)
                    @RenderServicoSimples("fa-box", "Armário", _modalBicicletario.TemArmario)
                    @RenderServicoSimples("fa-wrench", "Manutenção", _modalBicicletario.TemEspacoManutencao)
                    @RenderServicoSimples("fa-lock", "Cadeado", _modalBicicletario.TemCadeado)
                    @RenderServicoSimples("fa-restroom", "Banheiro", _modalBicicletario.TemBanheiro)
                </div>
            </div>

            @if (_rejeitandoB)
            {
                <div style="background:#FEF3C7; border:1px solid #FDE68A; border-radius:var(--r); padding:12px 14px; margin-bottom:12px;">
                    <div style="font-size:12px; font-weight:600; color:#92400E; font-family:var(--font); margin-bottom:8px;">Motivo da rejeição (opcional)</div>
                    <textarea @bind="_motivoB" placeholder="Ex: endereço incorreto, não existe..."
                              style="width:100%; box-sizing:border-box; border:1px solid #FDE68A; border-radius:var(--r); padding:8px 10px; font-family:var(--font); font-size:13px; color:var(--text); background:var(--bg); outline:none; resize:vertical; min-height:64px;" />
                </div>
            }

            @if (!string.IsNullOrEmpty(_erroB))
            {
                <div style="font-size:12px; color:#DC2626; margin-bottom:12px; font-family:var(--font);">@_erroB</div>
            }

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:8px;">
                <button @onclick="AprovarBicicletario" disabled="@_savingB"
                        style="padding:12px; border-radius:var(--r-lg); border:none; background:@(_savingB ? "var(--border)" : "#16A34A"); color:white; font-family:var(--font); font-size:14px; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:6px;">
                    <i class="fa-solid fa-check" style="font-size:12px;"></i>@(_savingB ? "..." : "Aprovar")
                </button>
                @if (!_rejeitandoB)
                {
                    <button @onclick="@(() => _rejeitandoB = true)" disabled="@_savingB"
                            style="padding:12px; border-radius:var(--r-lg); border:1px solid #F59E0B; background:#FEF3C7; color:#92400E; font-family:var(--font); font-size:14px; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:6px;">
                        <i class="fa-solid fa-xmark" style="font-size:12px;"></i>Rejeitar
                    </button>
                }
                else
                {
                    <button @onclick="RejeitarBicicletario" disabled="@_savingB"
                            style="padding:12px; border-radius:var(--r-lg); border:none; background:#F59E0B; color:white; font-family:var(--font); font-size:14px; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:6px;">
                        <i class="fa-solid fa-xmark" style="font-size:12px;"></i>Confirmar rejeição
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    private int _tab;
    private bool _isLoading = true;
    private string? _loadError;
    private int _contagemSugestoes;
    private int _contagemBicis;

    // Sugestões state
    private SugestaoDto[]? _pendentes;
    private SugestaoDto? _modalSugestao;
    private BicicletarioDetalheModel? _modalAtualB;
    private bool _modalCarregandoB;
    private bool _savingS;
    private bool _rejeitandoS;
    private string _motivoS = "";
    private string? _erroS;

    // Bicicletários pendentes state
    private BicicletarioPendenteModel[]? _pendentesB;
    private BicicletarioPendenteModel? _modalBicicletario;
    private bool _savingB;
    private bool _rejeitandoB;
    private string _motivoB = "";
    private string? _erroB;

    private static readonly string[] _dias = ["Dom", "Seg", "Ter", "Qua", "Qui", "Sex", "Sáb"];

    protected override async Task OnInitializedAsync()
    {
        var userInfo = await AuthSvc.GetUserInfoAsync();
        if (userInfo?.Type != 2)
        {
            Nav.NavigateTo("/lista");
            return;
        }

        var sugestoesTask  = SugestaoSvc.GetPendentesAsync();
        var bicicletariosTask = BicicletarioSvc.GetPendentesAsync();

        await Task.WhenAll(sugestoesTask, bicicletariosTask);

        var sugestoes = await sugestoesTask;
        var bicis = await bicicletariosTask;

        if (sugestoes == null && bicis == null)
            _loadError = "Não foi possível carregar os dados.";
        else
        {
            _pendentes  = sugestoes ?? [];
            _pendentesB = bicis ?? [];
            _contagemSugestoes = _pendentes.Length;
            _contagemBicis = _pendentesB.Length;
        }

        _isLoading = false;
    }

    // ── Sugestões modal ──────────────────────────────────────────
    private async Task AbrirModalSugestao(SugestaoDto s)
    {
        _modalSugestao = s;
        _modalAtualB = null;
        _modalCarregandoB = true;
        _erroS = null;
        _rejeitandoS = false;
        _motivoS = "";
        _modalAtualB = await BicicletarioSvc.GetByIdAsync(s.BicicletarioId);
        _modalCarregandoB = false;
        StateHasChanged();
    }

    private void FecharModalSugestao()
    {
        _modalSugestao = null;
        _modalAtualB = null;
        _rejeitandoS = false;
    }

    private async Task AprovarSugestao()
    {
        if (_modalSugestao == null) return;
        _savingS = true; _erroS = null;
        var err = await SugestaoSvc.AprovarAsync(_modalSugestao.Id);
        if (err == null)
        {
            _pendentes = _pendentes?.Where(s => s.Id != _modalSugestao.Id).ToArray();
            _contagemSugestoes = _pendentes?.Length ?? 0;
            FecharModalSugestao();
        }
        else _erroS = err;
        _savingS = false;
    }

    private async Task RejeitarSugestao()
    {
        if (_modalSugestao == null) return;
        _savingS = true; _erroS = null;
        var err = await SugestaoSvc.RejeitarAsync(_modalSugestao.Id, string.IsNullOrWhiteSpace(_motivoS) ? null : _motivoS);
        if (err == null)
        {
            _pendentes = _pendentes?.Where(s => s.Id != _modalSugestao.Id).ToArray();
            _contagemSugestoes = _pendentes?.Length ?? 0;
            FecharModalSugestao();
        }
        else _erroS = err;
        _savingS = false;
    }

    // ── Bicicletários modal ──────────────────────────────────────
    private void AbrirModalBicicletario(BicicletarioPendenteModel b)
    {
        _modalBicicletario = b;
        _erroB = null;
        _rejeitandoB = false;
        _motivoB = "";
    }

    private void FecharModalBicicletario()
    {
        _modalBicicletario = null;
        _rejeitandoB = false;
    }

    private async Task AprovarBicicletario()
    {
        if (_modalBicicletario == null) return;
        _savingB = true; _erroB = null;
        var err = await BicicletarioSvc.AprovarCriacaoAsync(_modalBicicletario.Id);
        if (err == null)
        {
            _pendentesB = _pendentesB?.Where(b => b.Id != _modalBicicletario.Id).ToArray();
            _contagemBicis = _pendentesB?.Length ?? 0;
            FecharModalBicicletario();
        }
        else _erroB = err;
        _savingB = false;
    }

    private async Task RejeitarBicicletario()
    {
        if (_modalBicicletario == null) return;
        _savingB = true; _erroB = null;
        var err = await BicicletarioSvc.RejeitarCriacaoAsync(_modalBicicletario.Id, string.IsNullOrWhiteSpace(_motivoB) ? null : _motivoB);
        if (err == null)
        {
            _pendentesB = _pendentesB?.Where(b => b.Id != _modalBicicletario.Id).ToArray();
            _contagemBicis = _pendentesB?.Length ?? 0;
            FecharModalBicicletario();
        }
        else _erroB = err;
        _savingB = false;
    }

    // ── Helpers ─────────────────────────────────────────────────
    private static string GetSecoesAlteradas(SugestaoDadosDto d)
    {
        var secoes = new List<string>();
        if (d.TemTomada.HasValue || d.TemCalibrador.HasValue || d.TemVestiario.HasValue ||
            d.TemArmario.HasValue || d.TemEspacoManutencao.HasValue || d.TemCadeado.HasValue || d.TemBanheiro.HasValue)
            secoes.Add("Serviços");
        if (d.AcessoLivre.HasValue || d.AcessoPago.HasValue || d.AcessoCadastro.HasValue || d.AcessoMensal.HasValue)
            secoes.Add("Acesso");
        if (d.VeiculosSuportados.HasValue)
            secoes.Add("Veículos");
        if (d.Horarios != null)
            secoes.Add("Horários");
        return secoes.Count > 0 ? string.Join(" · ", secoes) : "Dados gerais";
    }

    private static string VeiculoLabel(int flags)
    {
        var parts = new List<string>();
        if ((flags & 1) != 0) parts.Add("Bicicleta");
        if ((flags & 2) != 0) parts.Add("Scooter");
        if ((flags & 4) != 0) parts.Add("Monociclo");
        if ((flags & 8) != 0) parts.Add("Patinete");
        return parts.Count > 0 ? string.Join(", ", parts) : "Nenhum";
    }

    private static string FormatDate(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt.ToUniversalTime();
        if (diff.TotalMinutes < 2)  return "agora";
        if (diff.TotalHours  < 1)   return $"há {(int)diff.TotalMinutes} min";
        if (diff.TotalDays   < 1)   return $"há {(int)diff.TotalHours}h";
        if (diff.TotalDays   < 2)   return "ontem";
        if (diff.TotalDays   < 30)  return $"há {(int)diff.TotalDays} dias";
        var meses = (int)(diff.TotalDays / 30);
        if (diff.TotalDays   < 365) return $"há {meses} {(meses == 1 ? "mês" : "meses")}";
        var anos = (int)(diff.TotalDays / 365);
        return $"há {anos} ano{(anos > 1 ? "s" : "")}";
    }

    private RenderFragment RenderServico(string icon, string label, bool atual, bool? sugerido) => __builder =>
    {
        if (!sugerido.HasValue) return;
        __builder.OpenElement(0, "div");
        __builder.AddAttribute(1, "style", "display:flex; align-items:center; gap:6px;");
        __builder.OpenElement(2, "span");
        __builder.AddAttribute(3, "style", $"font-size:12px; color:{(atual ? "#16a34a" : "var(--text-4)")}; font-family:var(--font); flex:1;");
        __builder.AddMarkupContent(4, $"<i class=\"fa-solid {icon}\" style=\"font-size:10px; margin-right:4px;\"></i>{label}: {(atual ? "Sim" : "Não")}");
        __builder.CloseElement();
        __builder.OpenElement(5, "i");
        __builder.AddAttribute(6, "class", "fa-solid fa-arrow-right");
        __builder.AddAttribute(7, "style", "font-size:9px; color:var(--text-4);");
        __builder.CloseElement();
        __builder.OpenElement(8, "span");
        __builder.AddAttribute(9, "style", $"font-size:12px; font-weight:600; color:{(sugerido.Value ? "#16a34a" : "#DC2626")}; font-family:var(--font); flex:1;");
        __builder.AddMarkupContent(10, sugerido.Value ? "✓ Sim" : "✗ Não");
        __builder.CloseElement();
        __builder.CloseElement();
    };

    private RenderFragment RenderServicoSimples(string icon, string label, bool valor) => __builder =>
    {
        __builder.OpenElement(0, "div");
        __builder.AddAttribute(1, "style", $"font-size:12px; color:{(valor ? "#16a34a" : "var(--text-4)")}; font-family:var(--font); display:flex; align-items:center; gap:5px;");
        __builder.AddMarkupContent(2, $"<i class=\"fa-solid {icon}\" style=\"font-size:10px;\"></i>");
        __builder.AddContent(3, $"{label}: {(valor ? "Sim" : "Não")}");
        __builder.CloseElement();
    };
}
