@page "/adicionar/dados"
@layout AdicionarLayout
@inject NavigationManager Nav
@inject AuthService AuthService
@inject AdicionarStateService AdicionarState
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.Json
@using System.Text.Json.Serialization

<div class="@_slideClass">

@if (!_isAuthenticated)
{
    <div style="padding:48px 28px; display:flex; flex-direction:column; align-items:center; text-align:center; gap:16px;">
        <div style="width:64px; height:64px; border-radius:var(--r-full); background:var(--bg-page); border:1.5px solid var(--border); display:flex; align-items:center; justify-content:center;">
            <i class="fa-solid fa-lock" style="font-size:24px; color:var(--text-4);"></i>
        </div>
        <div>
            <div style="font-size:17px; font-weight:700; color:var(--text); font-family:var(--font); letter-spacing:-0.02em; margin-bottom:6px;">Acesso restrito</div>
            <div style="font-size:14px; color:var(--text-3); font-family:var(--font); line-height:1.5;">Para adicionar um bicicletário você precisa estar logado.</div>
        </div>
        <BtnP Style="width:100%; margin-top:8px;" OnClick="@(() => Nav.NavigateTo("/login"))">
            <i class="fa-solid fa-right-to-bracket" style="margin-right:8px;"></i> Fazer login
        </BtnP>
    </div>
}
else
{

<div style="padding:20px 20px 110px;">
    <div style="display:flex; flex-direction:column; gap:18px;">

        <!-- Foto -->
        <div>
            <label style="display:block; font-size:13px; font-weight:500; color:var(--text-2); margin-bottom:8px; font-family:var(--font);">
                Foto <span style="color:var(--text-4); font-weight:400;">(opcional)</span>
            </label>
            <div style="border:1.5px dashed var(--border-2); border-radius:var(--r-lg); overflow:hidden; height:160px; display:flex; align-items:center; justify-content:center; background:var(--bg-page); position:relative;">
                @if (_fotoPreview != null)
                {
                    <img src="@_fotoPreview" alt="Preview"
                         style="width:100%; height:100%; object-fit:cover;" />
                    <button type="button" @onclick="RemoverFoto"
                            style="position:absolute; top:8px; right:8px; width:28px; height:28px; border-radius:var(--r-full); background:rgba(0,0,0,0.5); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center;">
                        <i class="fa-solid fa-xmark" style="color:white; font-size:12px;"></i>
                    </button>
                }
                else
                {
                    <div style="display:flex; flex-direction:column; align-items:center; gap:8px; color:var(--text-4);">
                        <i class="fa-solid fa-image" style="font-size:24px;"></i>
                        <span style="font-size:13px; font-family:var(--font);">Nenhuma foto selecionada</span>
                    </div>
                }
            </div>
            <div style="display:flex; gap:8px; margin-top:8px;">
                <label for="fotoInput" style="flex:1; display:flex; align-items:center; justify-content:center; gap:6px; padding:9px; border:1px solid var(--border); border-radius:var(--r); cursor:pointer; font-size:13px; color:var(--text-2); font-family:var(--font); background:var(--bg-page);">
                    <i class="fa-solid fa-image"></i>
                    <span>Galeria</span>
                </label>
                <button type="button" @onclick="TirarFoto" disabled="@_isCameraLoading"
                        style="flex:1; display:flex; align-items:center; justify-content:center; gap:6px; padding:9px; border:1px solid var(--border); border-radius:var(--r); cursor:pointer; font-size:13px; color:var(--text-2); font-family:var(--font); background:var(--bg-page);">
                    <i class="fa-solid fa-camera"></i>
                    <span>@(_isCameraLoading ? "Aguarde..." : "Câmera")</span>
                </button>
            </div>
            <InputFile id="fotoInput" OnChange="OnFotoSelecionada"
                       accept="image/webp,image/png,image/jpeg,image/heic,image/heif"
                       style="display:none;" />
            <input id="cameraInputAdicionar" type="file" accept="image/*" capture="environment" style="display:none;" />
            @if (_fotoError != null)
            {
                <div style="font-size:12px; color:var(--red); margin-top:6px; font-family:var(--font);">
                    <i class="fa-solid fa-triangle-exclamation" style="margin-right:4px;"></i>@_fotoError
                </div>
            }
        </div>

        <!-- Nome -->
        <div>
            <label style="display:block; font-size:13px; font-weight:500; color:var(--text-2); margin-bottom:8px; font-family:var(--font);">
                Nome do bicicletário <span style="color:var(--brand);">*</span>
            </label>
            <WfInput Placeholder="Ex: Bicicletário Parque das Flores"
                     Value="@_name"
                     ValueChanged="@((v) => { _name = v; _nameError = null; })" />
            @if (_nameError != null)
            {
                <div style="font-size:12px; color:var(--red); margin-top:6px; font-family:var(--font);">
                    <i class="fa-solid fa-triangle-exclamation" style="margin-right:4px;"></i>@_nameError
                </div>
            }
        </div>

        <!-- Capacidade -->
        <div>
            <label style="display:block; font-size:13px; font-weight:500; color:var(--text-2); margin-bottom:8px; font-family:var(--font);">
                Capacidade <span style="color:var(--text-4); font-weight:400;">(número de vagas)</span>
            </label>
            <WfInput Placeholder="Ex: 20"
                     Type="number"
                     IconClass="fa-hashtag"
                     Value="@_capacity"
                     ValueChanged="@((v) => _capacity = v)" />
        </div>

        <!-- Tipo de acesso -->
        <div>
            <label style="display:block; font-size:13px; font-weight:500; color:var(--text-2); margin-bottom:10px; font-family:var(--font);">
                Tipo de acesso
            </label>
            <div style="display:flex; flex-direction:column; gap:8px;">
                <div @onclick="@(() => _accessType = 0)" style="cursor:pointer;">
                    <RadioItem Checked="@(_accessType == 0)">Livre — sem restrições</RadioItem>
                </div>
                <div @onclick="@(() => _accessType = 1)" style="cursor:pointer;">
                    <RadioItem Checked="@(_accessType == 1)">Pago — tarifa por uso</RadioItem>
                </div>
                <div @onclick="@(() => _accessType = 2)" style="cursor:pointer;">
                    <RadioItem Checked="@(_accessType == 2)">Requer cadastro prévio</RadioItem>
                </div>
                <div @onclick="@(() => _accessType = 3)" style="cursor:pointer;">
                    <RadioItem Checked="@(_accessType == 3)">Mensalidade</RadioItem>
                </div>
            </div>
        </div>

        <!-- Horários de Funcionamento -->
        <div>
            <label style="display:block; font-size:13px; font-weight:500; color:var(--text-2); margin-bottom:10px; font-family:var(--font);">
                Horário de funcionamento <span style="color:var(--text-4); font-weight:400;">(opcional)</span>
            </label>

            @* Presets de grupo *@
            <div style="background:var(--bg-page); border:1px solid var(--border); border-radius:var(--r); padding:10px; margin-bottom:10px;">
                <div style="font-size:11px; font-weight:600; color:var(--text-4); font-family:var(--font); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:8px;">Aplicar em grupo</div>
                <div style="display:flex; gap:6px; align-items:center; flex-wrap:wrap; margin-bottom:8px;">
                    <input type="time" value="@_presetAbertura" @oninput="@(e => _presetAbertura = e.Value?.ToString() ?? _presetAbertura)"
                           style="border:1px solid var(--border); border-radius:var(--r); padding:4px 8px; font-family:var(--font); font-size:13px; background:var(--bg); color:var(--text); outline:none;" />
                    <span style="color:var(--text-4); font-size:12px;">–</span>
                    <input type="time" value="@_presetFechamento" @oninput="@(e => _presetFechamento = e.Value?.ToString() ?? _presetFechamento)"
                           style="border:1px solid var(--border); border-radius:var(--r); padding:4px 8px; font-family:var(--font); font-size:13px; background:var(--bg); color:var(--text); outline:none;" />
                </div>
                <div style="display:flex; gap:6px; flex-wrap:wrap;">
                    <button type="button" @onclick="@(() => AplicarPreset(0, 1, 2, 3, 4, 5, 6))"
                            style="padding:4px 10px; border-radius:var(--r); border:1px solid var(--border); background:var(--bg); font-family:var(--font); font-size:12px; font-weight:600; color:var(--text-2); cursor:pointer;">
                        Todos
                    </button>
                    <button type="button" @onclick="@(() => AplicarPreset(1, 2, 3, 4, 5))"
                            style="padding:4px 10px; border-radius:var(--r); border:1px solid var(--border); background:var(--bg); font-family:var(--font); font-size:12px; font-weight:600; color:var(--text-2); cursor:pointer;">
                        Dias úteis
                    </button>
                    <button type="button" @onclick="@(() => AplicarPreset(1, 2, 3, 4, 5, 6))"
                            style="padding:4px 10px; border-radius:var(--r); border:1px solid var(--border); background:var(--bg); font-family:var(--font); font-size:12px; font-weight:600; color:var(--text-2); cursor:pointer;">
                        Seg–Sáb
                    </button>
                    <button type="button" @onclick="@(() => AplicarPreset(6))"
                            style="padding:4px 10px; border-radius:var(--r); border:1px solid var(--border); background:var(--bg); font-family:var(--font); font-size:12px; font-weight:600; color:var(--text-2); cursor:pointer;">
                        Sáb
                    </button>
                    <button type="button" @onclick="@(() => AplicarPreset(0))"
                            style="padding:4px 10px; border-radius:var(--r); border:1px solid var(--border); background:var(--bg); font-family:var(--font); font-size:12px; font-weight:600; color:var(--text-2); cursor:pointer;">
                        Dom
                    </button>
                </div>
            </div>

            @* Grade por dia *@
            <div style="display:flex; flex-direction:column; gap:6px;">
                @for (var i = 0; i < 7; i++)
                {
                    var idx = i;
                    var h = _horarios[idx];
                    <div style="display:flex; align-items:center; gap:8px;">
                        <button type="button" @onclick="@(() => { h.Ciclar(); StateHasChanged(); })" style="@HorarioBtnStyle(h.Estado)">
                            @_diasSemana[idx]
                        </button>
                        @if (h.Estado == "aberto")
                        {
                            <input type="time" value="@h.Abertura" @oninput="@(e => { h.Abertura = e.Value?.ToString() ?? h.Abertura; StateHasChanged(); })"
                                   style="flex:1; border:1px solid var(--border); border-radius:var(--r); padding:4px 8px; font-family:var(--font); font-size:13px; background:var(--bg-page); color:var(--text); outline:none;" />
                            <span style="color:var(--text-4); font-size:12px;">–</span>
                            <input type="time" value="@h.Fechamento" @oninput="@(e => { h.Fechamento = e.Value?.ToString() ?? h.Fechamento; StateHasChanged(); })"
                                   style="flex:1; border:1px solid var(--border); border-radius:var(--r); padding:4px 8px; font-family:var(--font); font-size:13px; background:var(--bg-page); color:var(--text); outline:none;" />
                        }
                        else if (h.Estado == "fechado")
                        {
                            <span style="font-size:12px; color:var(--text-3); font-family:var(--font);">Fechado</span>
                        }
                        else
                        {
                            <span style="font-size:12px; color:var(--text-4); font-family:var(--font);">—</span>
                        }
                    </div>
                }
            </div>
        </div>

    </div>
</div>

}
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "lat")]
    public string? LatStr { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "lng")]
    public string? LngStr { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "dir")]
    public string? Dir { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "name")]
    public string? NameParam { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "capacity")]
    public string? CapacityParam { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "accessType")]
    public string? AccessTypeParam { get; set; }

    [CascadingParameter] public AdicionarLayout Layout { get; set; } = default!;

    private string _name = "";
    private string _capacity = "";
    private int _accessType = 0;
    private string? _nameError;
    private bool _isAuthenticated;
    private string _slideClass = "";
    private string? _fotoPreview;
    private string? _fotoError;
    private bool _isCameraLoading;

    private static readonly string[] _diasSemana = ["Dom", "Seg", "Ter", "Qua", "Qui", "Sex", "Sáb"];
    // Estado: "ni" = não informado (default), "aberto" = com horários, "fechado" = explicitamente fechado
    private class HorarioItem
    {
        public string Estado = "ni";
        public string Abertura = "08:00";
        public string Fechamento = "18:00";
        public void Ciclar() => Estado = Estado switch { "ni" => "aberto", "aberto" => "fechado", _ => "ni" };
    }
    private HorarioItem[] _horarios = Enumerable.Range(0, 7).Select(_ => new HorarioItem()).ToArray();
    private string _presetAbertura = "08:00";
    private string _presetFechamento = "18:00";

    private static string HorarioBtnStyle(string estado) => estado switch
    {
        "aberto"  => "width:40px; font-size:11px; font-weight:600; padding:3px 6px; border-radius:var(--r); border:1px solid var(--brand); background:var(--brand-soft); color:var(--brand); cursor:pointer; font-family:var(--font); flex-shrink:0;",
        "fechado" => "width:40px; font-size:11px; font-weight:600; padding:3px 6px; border-radius:var(--r); border:1px solid var(--border); background:var(--bg-page); color:var(--text-3); cursor:pointer; font-family:var(--font); flex-shrink:0; text-decoration:line-through;",
        _         => "width:40px; font-size:11px; font-weight:600; padding:3px 6px; border-radius:var(--r); border:1px dashed var(--border-2); background:var(--bg-page); color:var(--text-4); cursor:pointer; font-family:var(--font); flex-shrink:0;",
    };

    private void AplicarPreset(params int[] dias)
    {
        foreach (var d in dias)
        {
            _horarios[d].Estado    = "aberto";
            _horarios[d].Abertura  = _presetAbertura;
            _horarios[d].Fechamento = _presetFechamento;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _slideClass = Dir == "back" ? "page-slide-back" : "page-slide-forward";
        Layout.SetNext("Próximo →", GoNext);
        var user = await AuthService.GetUserInfoAsync();
        _isAuthenticated = user is not null;

        if (!string.IsNullOrEmpty(NameParam)) _name = NameParam;
        if (!string.IsNullOrEmpty(CapacityParam)) _capacity = CapacityParam;
        if (int.TryParse(AccessTypeParam, out var at)) _accessType = at;

        if (AdicionarState.HasFoto)
            _fotoPreview = $"data:{AdicionarState.FotoContentType};base64,{Convert.ToBase64String(AdicionarState.FotoBytes!)}";

        foreach (var h in AdicionarState.Horarios)
        {
            _horarios[h.DiaSemana].Estado    = "aberto";
            _horarios[h.DiaSemana].Abertura  = h.HoraAbertura;
            _horarios[h.DiaSemana].Fechamento = h.HoraFechamento;
        }
    }

    private async Task OnFotoSelecionada(InputFileChangeEventArgs e)
    {
        _fotoError = null;
        var file = e.File;

        const long maxSize = 10L * 1024 * 1024;
        if (file.Size > maxSize)
        {
            _fotoError = "A foto deve ter no máximo 10 MB.";
            return;
        }

        var tiposPermitidos = new[] { "image/webp", "image/png", "image/jpeg", "image/heic", "image/heif" };
        var mimeType = string.IsNullOrWhiteSpace(file.ContentType) ? "image/jpeg" : file.ContentType.ToLowerInvariant();
        if (!tiposPermitidos.Contains(mimeType))
        {
            _fotoError = "Use PNG, JPG, WEBP ou HEIC.";
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: maxSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            await AplicarCompressao(ms.ToArray(), mimeType);
        }
        catch
        {
            _fotoError = "Não foi possível ler o arquivo.";
        }
    }

    private async Task TirarFoto()
    {
        _fotoError = null;
        _isCameraLoading = true;
        try
        {
            var json = await JS.InvokeAsync<string?>("imageCompressor.captureAndCompress", "cameraInputAdicionar", 1200, 0.85);
            if (json is null) return;
            var result = JsonSerializer.Deserialize<CameraResult>(json);
            if (result?.DataUrl is null) return;
            await AplicarDataUrl(result.DataUrl);
        }
        catch
        {
            _fotoError = "Não foi possível capturar a foto.";
        }
        finally
        {
            _isCameraLoading = false;
        }
    }

    private async Task AplicarCompressao(byte[] bytes, string mimeType)
    {
        var base64 = Convert.ToBase64String(bytes);
        var dataUrl = await JS.InvokeAsync<string?>("imageCompressor.compress", base64, mimeType, 1200, 0.85);
        if (dataUrl is null) { _fotoError = "Não foi possível comprimir a imagem."; return; }
        await AplicarDataUrl(dataUrl);
    }

    private Task AplicarDataUrl(string dataUrl)
    {
        var base64Part = dataUrl.Split(',')[1];
        var compressed = Convert.FromBase64String(base64Part);
        AdicionarState.FotoBytes = compressed;
        AdicionarState.FotoContentType = "image/jpeg";
        _fotoPreview = dataUrl;
        return Task.CompletedTask;
    }

    private record CameraResult([property: JsonPropertyName("dataUrl")] string? DataUrl);

    private void RemoverFoto()
    {
        AdicionarState.ClearFoto();
        _fotoPreview = null;
    }

    private Task GoNext()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _nameError = "O nome do bicicletário é obrigatório.";
            return Task.CompletedTask;
        }

        AdicionarState.Horarios = _horarios
            .Select((h, i) => h.Estado == "aberto" ? new HorarioModel { DiaSemana = i, HoraAbertura = h.Abertura, HoraFechamento = h.Fechamento } : null)
            .Where(h => h != null)
            .Select(h => h!)
            .ToArray();

        var name = Uri.EscapeDataString(_name.Trim());
        var cap = _capacity.Trim();
        Nav.NavigateTo($"/adicionar/servicos?lat={LatStr}&lng={LngStr}&name={name}&capacity={cap}&accessType={_accessType}");
        return Task.CompletedTask;
    }
}
