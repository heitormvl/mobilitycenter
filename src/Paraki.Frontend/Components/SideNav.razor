@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AuthService AuthService
@inject AdminService AdminSvc

<aside class="side-nav @(_collapsed ? "side-nav--collapsed" : "")">
    <a href="/inicio" class="side-nav__header" style="text-decoration:none; color:inherit;">
        <div class="side-nav__logo">
            <img src="icon-192.png" alt="Paraki" style="width:100%; height:100%; object-fit:cover; display:block;" />
        </div>
        <span class="side-nav__brand-name">Paraki</span>
    </a>

    <nav class="side-nav__items">
        @foreach (var item in GetItems())
        {
            var on = item.Id == Active;
            <div class="side-nav__item @(on ? "side-nav__item--active" : "") @(item.Fab ? "side-nav__item--fab" : "")"
                 @onclick="@(() => NavigateTo(item.Id, item.Route))"
                 title="@item.Label">
                <div class="side-nav__item-icon" style="position:relative;">
                    <i class="fa-solid @item.Icon"></i>
                    @if (item.Id == "admin" && _pendencias > 0)
                    {
                        <span style="position:absolute; top:-6px; right:-8px; background:#DC2626; color:white; font-size:9px; font-weight:700; font-family:var(--font); border-radius:var(--r-full); padding:1px 4px; min-width:14px; text-align:center; line-height:14px; pointer-events:none;">
                            @(_pendencias > 99 ? "99+" : _pendencias.ToString())
                        </span>
                    }
                </div>
                <span class="side-nav__item-label">@item.Label</span>
            </div>
        }
    </nav>

    <button class="side-nav__collapse-btn" @onclick="ToggleCollapseAsync" title="@(_collapsed ? "Expandir menu" : "Recolher menu")">
        <i class="fa-solid @(_collapsed ? "fa-chevron-right" : "fa-chevron-left")"></i>
    </button>
</aside>

@code {
    [Parameter] public string Active { get; set; } = "";

    private bool _collapsed;
    private bool _isAdmin;
    private int _pendencias;

    private readonly (string Id, string Icon, string Label, bool Fab, string Route)[] _baseItems =
    [
        ("mapa",   "fa-map-location-dot", "Mapa",      false, "/"),
        ("lista",  "fa-list",             "Lista",     false, "/lista"),
        ("add",    "fa-plus",             "Adicionar", true,  "/adicionar"),
        ("perfil", "fa-user",             "Perfil",    false, "/perfil"),
    ];

    private (string Id, string Icon, string Label, bool Fab, string Route)[] GetItems()
    {
        if (!_isAdmin) return _baseItems;
        return [.. _baseItems, ("admin", "fa-shield-halved", "Admin", false, "/admin")];
    }

    protected override async Task OnInitializedAsync()
    {
        var userInfo = await AuthService.GetUserInfoAsync();
        _isAdmin = userInfo?.Type == 2;

        if (_isAdmin)
        {
            var contagem = await AdminSvc.GetContagemAsync();
            _pendencias = contagem?.Total ?? 0;
        }
    }

    private async Task ToggleCollapseAsync()
    {
        _collapsed = !_collapsed;
        await JS.InvokeVoidAsync("setCssVar", "--sidebar-w", _collapsed ? "64px" : "240px");
    }

    private async Task NavigateTo(string targetId, string route)
    {
        var currentPath = new Uri(Nav.Uri).AbsolutePath;
        if (targetId == Active && currentPath == route) return;
        await JS.InvokeVoidAsync("navTransition.prepare", Active, targetId);
        Nav.NavigateTo(route);
    }
}
