<div style="height:@(H)px; width:100%; flex-shrink:0; background:linear-gradient(135deg, #E8E4DF 0%, #D8D4CF 100%); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; color:var(--text-4);">
    <i class="fa-regular fa-image" style="font-size:28px;"></i>
    <span style="font-size:13px; font-weight:500; font-family:var(--font); color:var(--text-4);">@Label</span>
</div>

@code {
    [Parameter] public int H { get; set; } = 160;
    [Parameter] public string Label { get; set; } = "Foto do local";
}
