<div style="display:flex; justify-content:space-between; align-items:center; padding:12px 22px 6px; color:@(Dark ? "#FFFFFF" : "var(--text)"); font-family:var(--font);">
    <span style="font-size:15px; font-weight:600; letter-spacing:-0.01em;">9:41</span>
    <div style="display:flex; align-items:center; gap:5px; opacity:0.9;">
        <i class="fa-solid fa-signal" style="font-size:11px;"></i>
        <i class="fa-solid fa-wifi" style="font-size:11px;"></i>
        <i class="fa-solid fa-battery-full" style="font-size:14px;"></i>
    </div>
</div>

@code {
    [Parameter] public bool Dark { get; set; }
}
