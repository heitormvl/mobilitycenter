@page "/adicionar/dados"
@layout AdicionarLayout
@inject NavigationManager Nav
@inject AuthService AuthService

<div class="@_slideClass">

@if (!_isAuthenticated)
{
    <div style="padding:48px 28px; display:flex; flex-direction:column; align-items:center; text-align:center; gap:16px;">
        <div style="width:64px; height:64px; border-radius:var(--r-full); background:var(--bg-page); border:1.5px solid var(--border); display:flex; align-items:center; justify-content:center;">
            <i class="fa-solid fa-lock" style="font-size:24px; color:var(--text-4);"></i>
        </div>
        <div>
            <div style="font-size:17px; font-weight:700; color:var(--text); font-family:var(--font); letter-spacing:-0.02em; margin-bottom:6px;">Acesso restrito</div>
            <div style="font-size:14px; color:var(--text-3); font-family:var(--font); line-height:1.5;">Para adicionar um bicicletário você precisa estar logado.</div>
        </div>
        <BtnP Style="width:100%; margin-top:8px;" OnClick="@(() => Nav.NavigateTo("/login"))">
            <i class="fa-solid fa-right-to-bracket" style="margin-right:8px;"></i> Fazer login
        </BtnP>
    </div>
}
else
{

<div style="padding:20px 20px 110px;">
    <div style="display:flex; flex-direction:column; gap:18px;">

        <!-- Nome -->
        <div>
            <label style="display:block; font-size:13px; font-weight:500; color:var(--text-2); margin-bottom:8px; font-family:var(--font);">
                Nome do bicicletário <span style="color:var(--brand);">*</span>
            </label>
            <WfInput Placeholder="Ex: Bicicletário Parque das Flores"
                     Value="@_name"
                     ValueChanged="@((v) => { _name = v; _nameError = null; })" />
            @if (_nameError != null)
            {
                <div style="font-size:12px; color:var(--red); margin-top:6px; font-family:var(--font);">
                    <i class="fa-solid fa-triangle-exclamation" style="margin-right:4px;"></i>@_nameError
                </div>
            }
        </div>

        <!-- Capacidade -->
        <div>
            <label style="display:block; font-size:13px; font-weight:500; color:var(--text-2); margin-bottom:8px; font-family:var(--font);">
                Capacidade <span style="color:var(--text-4); font-weight:400;">(número de vagas)</span>
            </label>
            <WfInput Placeholder="Ex: 20"
                     Type="number"
                     IconClass="fa-hashtag"
                     Value="@_capacity"
                     ValueChanged="@((v) => _capacity = v)" />
        </div>

        <!-- Tipo de acesso -->
        <div>
            <label style="display:block; font-size:13px; font-weight:500; color:var(--text-2); margin-bottom:10px; font-family:var(--font);">
                Tipo de acesso
            </label>
            <div style="display:flex; flex-direction:column; gap:8px;">
                <div @onclick="@(() => _accessType = 0)" style="cursor:pointer;">
                    <RadioItem Checked="@(_accessType == 0)">Livre — sem restrições</RadioItem>
                </div>
                <div @onclick="@(() => _accessType = 1)" style="cursor:pointer;">
                    <RadioItem Checked="@(_accessType == 1)">Pago — tarifa por uso</RadioItem>
                </div>
                <div @onclick="@(() => _accessType = 2)" style="cursor:pointer;">
                    <RadioItem Checked="@(_accessType == 2)">Requer cadastro prévio</RadioItem>
                </div>
                <div @onclick="@(() => _accessType = 3)" style="cursor:pointer;">
                    <RadioItem Checked="@(_accessType == 3)">Mensalidade</RadioItem>
                </div>
            </div>
        </div>

    </div>
</div>

}
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "lat")]
    public string? LatStr { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "lng")]
    public string? LngStr { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "dir")]
    public string? Dir { get; set; }

    [CascadingParameter] public AdicionarLayout Layout { get; set; } = default!;

    private string _name = "";
    private string _capacity = "";
    private int _accessType = 0;
    private string? _nameError;
    private bool _isAuthenticated;
    private string _slideClass = "";

    protected override async Task OnInitializedAsync()
    {
        _slideClass = Dir == "back" ? "page-slide-back" : "page-slide-forward";
        Layout.SetNext("Próximo →", GoNext);
        var user = await AuthService.GetUserInfoAsync();
        _isAuthenticated = user is not null;
    }

    private Task GoNext()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _nameError = "O nome do bicicletário é obrigatório.";
            return Task.CompletedTask;
        }

        var name = Uri.EscapeDataString(_name.Trim());
        var cap = _capacity.Trim();
        Nav.NavigateTo($"/adicionar/servicos?lat={LatStr}&lng={LngStr}&name={name}&capacity={cap}&accessType={_accessType}");
        return Task.CompletedTask;
    }
}
