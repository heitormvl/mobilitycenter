@page "/adicionar/servicos"
@inject NavigationManager Nav
@inject BicicletarioService BicicletarioSvc
@inject AuthService AuthService

<!-- Header -->
<div style="background:var(--bg); border-bottom:1px solid var(--border);">
    <StatusBar />
    <div style="display:flex; align-items:center; gap:14px; padding:4px 20px 14px;">
        <button @onclick="GoBack" style="width:36px; height:36px; border-radius:var(--r-full); background:var(--bg-page); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
            <i class="fa-solid fa-chevron-left" style="color:var(--text-2); font-size:13px;"></i>
        </button>
        <div style="flex:1;">
            <div style="font-size:17px; font-weight:700; color:var(--text); font-family:var(--font); letter-spacing:-0.02em;">Serviços e veículos</div>
        </div>
    </div>
</div>

@if (!_isAuthenticated)
{
    <div style="padding:48px 28px; display:flex; flex-direction:column; align-items:center; text-align:center; gap:16px;">
        <div style="width:64px; height:64px; border-radius:var(--r-full); background:var(--bg-page); border:1.5px solid var(--border); display:flex; align-items:center; justify-content:center;">
            <i class="fa-solid fa-lock" style="font-size:24px; color:var(--text-4);"></i>
        </div>
        <div>
            <div style="font-size:17px; font-weight:700; color:var(--text); font-family:var(--font); letter-spacing:-0.02em; margin-bottom:6px;">Acesso restrito</div>
            <div style="font-size:14px; color:var(--text-3); font-family:var(--font); line-height:1.5;">Para adicionar um bicicletário você precisa estar logado.</div>
        </div>
        <BtnP Style="width:100%; margin-top:8px;" OnClick="@(() => Nav.NavigateTo("/login"))">
            <i class="fa-solid fa-right-to-bracket" style="margin-right:8px;"></i> Fazer login
        </BtnP>
    </div>
    return;
}

<div style="padding:20px 20px 110px; overflow-y:auto;">
    <ProgressBar Step="3" Total="3" />

    <!-- Serviços -->
    <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid var(--border); padding:16px; margin-bottom:14px;">
        <SecLabel>Serviços disponíveis</SecLabel>
        @foreach (var s in _servicos)
        {
            var item = s;
            <div @onclick="() => item.Checked = !item.Checked">
                <CheckItem Checked="@item.Checked">
                    <div style="display:flex; align-items:center; gap:10px; font-family:var(--font); font-size:14px; color:var(--text-2);">
                        <div style="width:28px; height:28px; border-radius:var(--r-sm); background:var(--bg-page); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <i class="fa-solid @item.Icon" style="color:var(--text-4); font-size:12px;"></i>
                        </div>
                        <span>@item.Label</span>
                    </div>
                </CheckItem>
            </div>
        }
    </div>

    <!-- Veículos -->
    <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid var(--border); padding:16px; margin-bottom:14px;">
        <SecLabel>Veículos suportados</SecLabel>
        @foreach (var v in _veiculos)
        {
            var item = v;
            <div @onclick="() => item.Checked = !item.Checked">
                <CheckItem Checked="@item.Checked">
                    <div style="display:flex; align-items:center; gap:10px; font-family:var(--font); font-size:14px; color:var(--text-2);">
                        <div style="width:28px; height:28px; border-radius:var(--r-sm); background:var(--bg-page); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <i class="fa-solid @item.Icon" style="color:var(--text-4); font-size:12px;"></i>
                        </div>
                        <span>@item.Label</span>
                    </div>
                </CheckItem>
            </div>
        }
    </div>

    @if (_publishError != null)
    {
        <div style="font-size:13px; color:#c0392b; font-family:var(--font); padding:10px 14px; background:#fdf2f2; border-radius:var(--r); border:1px solid #f5c6c6;">
            <i class="fa-solid fa-triangle-exclamation" style="margin-right:6px;"></i>@_publishError
        </div>
    }
</div>

<div style="position:absolute; bottom:24px; left:16px; right:16px; display:flex; flex-direction:column; gap:10px;">
    <BtnP OnClick="PublishAsync">
        @if (_isPublishing)
        {
            <i class="fa-solid fa-spinner fa-spin" style="margin-right:8px;"></i>
            <span>Publicando...</span>
        }
        else
        {
            <span>Publicar bicicletário</span>
        }
    </BtnP>
    <BtnO OnClick="GoBack">
        <i class="fa-solid fa-chevron-left" style="font-size:12px;"></i> Voltar
    </BtnO>
</div>

@code {
    [Parameter] [SupplyParameterFromQuery(Name = "lat")]        public string? LatStr      { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "lng")]        public string? LngStr      { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "name")]       public string? Name        { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "capacity")]   public string? Capacity    { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "accessType")] public string? AccessType  { get; set; }

    private bool _isPublishing;
    private string? _publishError;
    private bool _isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetUserInfoAsync();
        _isAuthenticated = user is not null;
    }

    private CheckOption[] _servicos =
    [
        new("fa-plug",   "Tomada elétrica",        true),
        new("fa-gauge",  "Calibrador de pneus",     true),
        new("fa-box",    "Armário / guarda-volume", false),
        new("fa-wrench", "Espaço de manutenção",    false),
        new("fa-lock",   "Cadeado próprio",         false),
    ];

    private CheckOption[] _veiculos =
    [
        new("fa-bicycle",       "Bicicleta",         true),
        new("fa-person-biking", "Scooter",           false),
        new("fa-bolt",          "Patinete elétrico", false),
        new("fa-circle-dot",    "Monociclo",         false),
    ];

    private void GoBack() =>
        Nav.NavigateTo($"/adicionar/dados?lat={LatStr}&lng={LngStr}&name={Uri.EscapeDataString(Name ?? "")}&capacity={Capacity}&accessType={AccessType}");

    private async Task PublishAsync()
    {
        if (_isPublishing) return;
        _isPublishing = true;
        _publishError = null;
        StateHasChanged();

        var (error, _) = await BicicletarioSvc.CreateAsync(BuildRequest());

        if (error != null)
        {
            _publishError = error;
            _isPublishing = false;
            StateHasChanged();
            return;
        }

        Nav.NavigateTo("/", forceLoad: false);
    }

    private CreateBicicletarioRequest BuildRequest()
    {
        var accessType = int.TryParse(AccessType, out var at) ? at : 0;

        return new CreateBicicletarioRequest
        {
            Nome = Name ?? "",
            Latitude = double.TryParse(LatStr, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var lat) ? lat : 0,
            Longitude = double.TryParse(LngStr, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var lng) ? lng : 0,
            TemTomada           = _servicos[0].Checked,
            TemCalibrador       = _servicos[1].Checked,
            TemArmario          = _servicos[2].Checked,
            TemEspacoManutencao = _servicos[3].Checked,
            TemCadeado          = _servicos[4].Checked,
            TemVestiario        = false,
            AcessoLivre         = accessType == 0,
            AcessoPago          = accessType == 1,
            AcessoCadastro      = accessType == 2,
            AcessoMensal        = accessType == 3,
            // TipoVeiculo flags: Bicicleta=1, Scooter=2, Monociclo=4, Patinete=8
            VeiculosSuportados  = (_veiculos[0].Checked ? 1 : 0)   // Bicicleta
                                | (_veiculos[1].Checked ? 2 : 0)   // Scooter
                                | (_veiculos[2].Checked ? 8 : 0)   // Patinete (fa-bolt)
                                | (_veiculos[3].Checked ? 4 : 0),  // Monociclo (fa-circle-dot)
        };
    }

    private class CheckOption(string icon, string label, bool @checked)
    {
        public string Icon    { get; } = icon;
        public string Label   { get; } = label;
        public bool   Checked { get; set; } = @checked;
    }
}
