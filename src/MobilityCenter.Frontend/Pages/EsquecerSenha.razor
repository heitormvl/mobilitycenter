@page "/esqueci-senha"
@inject NavigationManager Nav
@inject AuthService AuthService

<div style="min-height:100vh; display:flex; flex-direction:column; background:linear-gradient(160deg, var(--brand) 0%, var(--brand-dark) 100%);">

    <StatusBar Dark="true" />

    <div style="padding:36px 28px 60px; text-align:center; flex-shrink:0; position:relative;">
        <a href="/login"
           style="position:absolute; top:0; left:28px; background:rgba(255,255,255,0.18); border:1.5px solid rgba(255,255,255,0.28); border-radius:50%; width:38px; height:38px; display:flex; align-items:center; justify-content:center; backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px); text-decoration:none;">
            <i class="fa-solid fa-chevron-left" style="color:white; font-size:15px;"></i>
        </a>
        <div style="width:76px; height:76px; border-radius:24px; background:rgba(255,255,255,0.18); backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px); border:1.5px solid rgba(255,255,255,0.28); margin:0 auto 20px; display:flex; align-items:center; justify-content:center;">
            <i class="fa-solid fa-lock" style="font-size:34px; color:white;"></i>
        </div>
        <h1 style="font-size:28px; font-weight:800; color:white; font-family:var(--font); letter-spacing:-0.03em; margin-bottom:6px; text-shadow:0 2px 8px rgba(0,0,0,0.18);">Esqueci minha senha</h1>
        <p style="font-size:14px; color:rgba(255,255,255,0.72); font-family:var(--font);">Enviaremos um link de redefinição</p>
    </div>

    <div style="flex:1; background:var(--bg); border-radius:28px 28px 0 0; margin-top:-32px; padding:32px 24px 52px;">

        @if (_sucesso)
        {
            <div style="display:flex; flex-direction:column; align-items:center; text-align:center; padding-top:24px;">
                <div style="width:72px; height:72px; background:#e8f8f0; border-radius:50%; display:flex; align-items:center; justify-content:center; margin-bottom:24px;">
                    <i class="fa-solid fa-envelope-circle-check" style="font-size:32px; color:var(--brand);"></i>
                </div>
                <p style="font-size:22px; font-weight:800; color:var(--text); font-family:var(--font); letter-spacing:-0.03em; margin-bottom:8px;">E-mail enviado!</p>
                <p style="font-size:14px; color:var(--text-3); font-family:var(--font); line-height:1.6; margin-bottom:32px;">
                    Se o endereço <strong style="color:var(--text);">@_email</strong> estiver cadastrado, você receberá um link para redefinir sua senha em instantes.
                </p>
                <a href="/login" style="font-size:14px; color:var(--brand); font-weight:600; text-decoration:none; font-family:var(--font);">Voltar ao login</a>
            </div>
        }
        else
        {
            <p style="font-size:22px; font-weight:800; color:var(--text); font-family:var(--font); letter-spacing:-0.03em; margin-bottom:4px;">Redefinir senha</p>
            <p style="font-size:14px; color:var(--text-3); font-family:var(--font); margin-bottom:28px;">Informe o e-mail da sua conta</p>

            <div style="margin-bottom:24px;">
                <label style="display:block; font-size:13px; font-weight:500; color:var(--text-2); margin-bottom:8px; font-family:var(--font);">E-mail</label>
                <WfInput @bind-Value="_email" Placeholder="seu@email.com" IconClass="fa-envelope" />
            </div>

            @if (_erro != null)
            {
                <div style="background:var(--red-bg); border:1px solid var(--red-border); border-radius:var(--r); padding:12px 14px; margin-bottom:16px; font-family:var(--font); font-size:13px; color:var(--red);">
                    @_erro
                </div>
            }

            <BtnP OnClick="HandleEnviar" Style="margin-bottom:20px;">
                @if (_loading) { <span>Enviando...</span> } else { <span>Enviar link</span> }
            </BtnP>

            <div style="text-align:center;">
                <a href="/login" style="font-size:14px; color:var(--text-3); font-family:var(--font); text-decoration:none;">Voltar ao login</a>
            </div>
        }

    </div>
</div>

@code {
    private string _email = "";
    private bool _loading;
    private string? _erro;
    private bool _sucesso;

    private async Task HandleEnviar()
    {
        if (string.IsNullOrWhiteSpace(_email))
        {
            _erro = "Informe seu e-mail.";
            return;
        }

        _loading = true;
        _erro = null;

        var erro = await AuthService.EsquecerSenhaAsync(_email);
        if (erro is null)
            _sucesso = true;
        else
            _erro = erro;

        _loading = false;
    }
}
