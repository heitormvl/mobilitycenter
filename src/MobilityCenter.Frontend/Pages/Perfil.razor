@page "/perfil"
@inject NavigationManager Nav
@inject AuthService AuthService

<!-- Header -->
<div style="background:var(--bg); border-bottom:1px solid var(--border);">
    <StatusBar />
    <div style="display:flex; justify-content:space-between; align-items:center; padding:4px 20px 14px;">
        <h1 style="font-size:24px; font-weight:800; color:var(--text); font-family:var(--font); letter-spacing:-0.03em;">Perfil</h1>
        <button style="width:36px; height:36px; border-radius:var(--r-full); background:var(--bg-page); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center;">
            <i class="fa-solid fa-gear" style="color:var(--text-3); font-size:15px;"></i>
        </button>
    </div>
</div>

<div style="padding:20px 20px 88px; overflow-y:auto;">
    @if (_loading)
    {
        <div style="text-align:center; padding:40px; color:var(--text-4); font-family:var(--font);">Carregando...</div>
    }
    else if (_user != null)
    {
        <!-- Avatar + name -->
        <div style="background:var(--bg); border-radius:var(--r-xl); border:1px solid var(--border); padding:24px 20px; margin-bottom:14px; text-align:center; box-shadow:var(--shadow-sm);">
            <div style="position:relative; display:inline-block; margin-bottom:14px;">
                <div style="width:80px; height:80px; border-radius:var(--r-full); background:var(--bg-page); border:3px solid var(--brand); display:flex; align-items:center; justify-content:center;">
                    <i class="fa-solid fa-user" style="font-size:30px; color:var(--text-4);"></i>
                </div>
                <div style="position:absolute; bottom:0; right:0; width:24px; height:24px; border-radius:var(--r-full); background:var(--brand); border:2.5px solid var(--bg); display:flex; align-items:center; justify-content:center;">
                    <i class="fa-solid fa-pen" style="font-size:9px; color:white;"></i>
                </div>
            </div>
            <div style="font-size:20px; font-weight:700; color:var(--text); font-family:var(--font); letter-spacing:-0.02em; margin-bottom:4px;">@_user.DisplayName</div>
            <div style="font-size:13px; color:var(--text-4); font-family:var(--font);">Membro desde @_user.CreatedAt.ToString("MMMM \\de yyyy")</div>
        </div>

        <!-- Stats -->
        <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom:24px;">
            <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid var(--border); padding:16px 10px; text-align:center; box-shadow:var(--shadow-sm);">
                <div style="font-size:26px; font-weight:800; color:var(--brand); font-family:var(--font); letter-spacing:-0.02em; line-height:1;">@_totalAvaliacoes</div>
                <div style="font-size:11px; color:var(--text-4); font-family:var(--font); margin-top:5px; font-weight:500;">Avaliações</div>
            </div>
            <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid var(--border); padding:16px 10px; text-align:center; box-shadow:var(--shadow-sm);">
                <div style="font-size:26px; font-weight:800; color:var(--brand); font-family:var(--font); letter-spacing:-0.02em; line-height:1;">@_totalAdicionados</div>
                <div style="font-size:11px; color:var(--text-4); font-family:var(--font); margin-top:5px; font-weight:500;">Adicionados</div>
            </div>
            <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid var(--border); padding:16px 10px; text-align:center; box-shadow:var(--shadow-sm);">
                <div style="font-size:26px; font-weight:800; color:var(--brand); font-family:var(--font); letter-spacing:-0.02em; line-height:1;">—</div>
                <div style="font-size:11px; color:var(--text-4); font-family:var(--font); margin-top:5px; font-weight:500;">Visitados</div>
            </div>
        </div>

        <!-- Sign out -->
        <div style="margin-top:20px;">
            <button @onclick="HandleSignOut" style="width:100%; background:var(--bg); border:1.5px solid var(--border); border-radius:var(--r-lg); padding:14px 20px; font-family:var(--font); font-size:15px; font-weight:500; color:var(--red); cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px;">
                <i class="fa-solid fa-arrow-right-from-bracket" style="font-size:14px;"></i>
                Sair da conta
            </button>
        </div>
    }
</div>

<BottomNav Active="perfil" />

@code {
    private UserInfo? _user;
    private int _totalAvaliacoes;
    private int _totalAdicionados;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _user = await AuthService.GetUserInfoAsync();

        if (_user is null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        var perfil = await AuthService.GetPerfilAsync();
        if (perfil is not null)
        {
            _totalAvaliacoes = perfil.TotalAvaliacoes;
            _totalAdicionados = perfil.TotalAdicionados;
        }

        _loading = false;
    }

    private async Task HandleSignOut()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/login");
    }
}
