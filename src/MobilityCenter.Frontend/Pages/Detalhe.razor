@page "/bicicletario/{Id}"
@using System.Text.Json.Serialization
@using System.Globalization
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms
@using MobilityCenter.Frontend.Models
@inject NavigationManager Nav
@inject BicicletarioService BicicletarioSvc
@inject AuthService AuthSvc
@inject IJSRuntime JS
@inject IHttpClientFactory HttpFactory

@* Sticky header *@
<div style="background:var(--bg); border-bottom:1px solid var(--border); position:sticky; top:0; z-index:20;">
    <StatusBar />
    <div style="display:flex; align-items:center; gap:14px; padding:4px 20px 14px;">
        <button @onclick="@(() => Nav.NavigateTo("/lista"))"
                style="width:36px; height:36px; border-radius:var(--r-full); background:var(--bg-page); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
            <i class="fa-solid fa-chevron-left" style="color:var(--text-2); font-size:13px;"></i>
        </button>
        <span style="font-size:17px; font-weight:700; color:var(--text); font-family:var(--font); letter-spacing:-0.02em; flex:1; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
            @(_isLoading ? "Carregando..." : (_item?.Nome ?? "Não encontrado"))
        </span>
        @if (_isAdmin && !_isLoading && _item != null)
        {
            <div style="display:flex; align-items:center; gap:6px; padding:4px 10px; border-radius:var(--r-full); background:#FEE2E2; border:1px solid #FCA5A5;">
                <i class="fa-solid fa-shield-halved" style="font-size:10px; color:#DC2626;"></i>
                <span style="font-size:11px; font-weight:700; color:#DC2626; font-family:var(--font); letter-spacing:0.04em;">ADMIN</span>
            </div>
        }
    </div>
</div>

@if (_isLoading)
{
    @* Skeleton *@
    <div style="height:200px; background:var(--border);"></div>
    <div style="padding:20px; display:flex; flex-direction:column; gap:14px;">
        <div style="display:flex; gap:8px; align-items:center;">
            <div style="height:14px; width:120px; background:var(--border); border-radius:4px;"></div>
            <div style="height:12px; width:80px; background:var(--border); border-radius:4px;"></div>
        </div>
        <div style="height:12px; width:70%; background:var(--border); border-radius:4px;"></div>
        <div style="height:96px; background:var(--border); border-radius:var(--r-lg); margin-top:8px;"></div>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
            <div style="height:80px; background:var(--border); border-radius:var(--r-lg);"></div>
            <div style="height:80px; background:var(--border); border-radius:var(--r-lg);"></div>
        </div>
        <div style="height:90px; background:var(--border); border-radius:var(--r-lg);"></div>
        <div style="height:90px; background:var(--border); border-radius:var(--r-lg);"></div>
    </div>
}
else if (_loadError != null)
{
    @* Error state *@
    <div style="text-align:center; padding:60px 24px; font-family:var(--font);">
        <i class="fa-solid fa-triangle-exclamation" style="font-size:40px; color:var(--text-4); margin-bottom:16px; display:block;"></i>
        <div style="font-size:16px; font-weight:600; color:var(--text); margin-bottom:8px;">Oops!</div>
        <div style="font-size:14px; color:var(--text-3); margin-bottom:24px;">@_loadError</div>
        <BtnO OnClick="@(() => Nav.NavigateTo("/lista"))">
            <i class="fa-solid fa-arrow-left" style="margin-right:6px;"></i> Voltar à lista
        </BtnO>
    </div>
}
else if (_item != null)
{
    @* Lightbox *@
    @if (_lightboxOpen && _fotoUrl != null)
    {
        <div @onclick="@(() => _lightboxOpen = false)"
             style="position:fixed; inset:0; z-index:200; background:rgba(0,0,0,0.92); display:flex; align-items:center; justify-content:center; padding:24px; cursor:zoom-out;">
            <img src="@_fotoUrl"
                 style="max-width:min(90vw,800px); max-height:80vh; object-fit:contain; border-radius:var(--r-lg); box-shadow:0 24px 64px rgba(0,0,0,0.6);"
                 alt="Foto do local"
                 @onclick:stopPropagation="true" />
            <button @onclick="@(() => _lightboxOpen = false)"
                    style="position:absolute; top:16px; right:16px; width:40px; height:40px; border-radius:var(--r-full); background:rgba(255,255,255,0.15); border:1px solid rgba(255,255,255,0.25); cursor:pointer; display:flex; align-items:center; justify-content:center;">
                <i class="fa-solid fa-xmark" style="color:white; font-size:15px;"></i>
            </button>
        </div>
    }

    @* Photo section *@
    <div style="position:relative; background:#111;">
        @if (!_fotoFalhou && _fotoUrl != null)
        {
            <img src="@_fotoUrl"
                 style="width:100%; max-height:320px; object-fit:contain; display:block; cursor:zoom-in;"
                 alt="Foto do local"
                 @onclick="@(() => _lightboxOpen = true)"
                 @onerror="@(() => _fotoFalhou = true)" />
        }
        else
        {
            <ImgPH H="200" Label="Foto do local" />
        }
        @if (_isAdmin)
        {
            <button @onclick="@(() => { _editingFoto = !_editingFoto; _saveError = null; })"
                    style="position:absolute; top:12px; right:12px; width:36px; height:36px; border-radius:var(--r-full); background:rgba(0,0,0,0.5); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center;">
                <i class="fa-solid @(_editingFoto ? "fa-xmark" : "fa-pen")" style="font-size:13px; color:white;"></i>
            </button>
        }
        @if (_isAdmin && _editingFoto)
        {
            <div style="position:absolute; bottom:0; left:0; right:0; background:rgba(0,0,0,0.75); padding:14px 16px; display:flex; align-items:center; gap:10px;">
                <label style="flex:1; display:flex; align-items:center; gap:8px; cursor:pointer; color:white; font-size:14px; font-family:var(--font); font-weight:500;">
                    <i class="fa-solid fa-image"></i>
                    @if (_isSaving) { <span>Enviando...</span> } else { <span>Escolher foto (webp, png, jpg · max 5MB)</span> }
                    <InputFile OnChange="HandleFotoUpload" accept="image/webp,image/png,image/jpeg" style="display:none;" disabled="@_isSaving" />
                </label>
            </div>
            @if (!string.IsNullOrEmpty(_saveError))
            {
                <div style="position:absolute; top:0; left:0; right:0; background:rgba(220,38,38,0.85); padding:8px 14px; font-size:12px; color:white; font-family:var(--font);">
                    @_saveError
                </div>
            }
        }
    </div>

    @* Scrollable body *@
    <div style="padding:20px 20px 160px;">

        @* Rating + address *@
        <div style="margin-bottom:20px;">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px; flex-wrap:wrap;">
                <Stars N="@((int)Math.Round(_item.NotaMedia))" Size="15" />
                <span style="font-size:14px; font-weight:600; color:var(--text); font-family:var(--font);">
                    @(_item.NotaMedia > 0
                        ? _item.NotaMedia.ToString("F1", CultureInfo.InvariantCulture).Replace('.', ',')
                        : "—")
                </span>
                <span style="font-size:13px; color:var(--text-4); font-family:var(--font);">
                    · @(_item.Avaliacoes.Length switch {
                        0 => "Sem avaliações",
                        1 => "1 avaliação",
                        _ => $"{_item.Avaliacoes.Length} avaliações"
                    })
                </span>
            </div>
            @if (!string.IsNullOrEmpty(_address))
            {
                <div style="display:flex; align-items:flex-start; gap:6px; color:var(--text-3); font-size:13px; font-family:var(--font); line-height:1.4;">
                    <i class="fa-solid fa-location-dot" style="color:var(--brand); font-size:12px; margin-top:2px; flex-shrink:0;"></i>
                    <span>@_address</span>
                </div>
            }
        </div>

        @* Services card *@
        <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid @(_editingServicos ? "var(--brand)" : "var(--border)"); padding:16px; margin-bottom:12px; box-shadow:var(--shadow-xs); transition:border-color 0.15s;">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:10px;">
                <div style="font-family:var(--font); font-size:11px; font-weight:600; color:var(--text-4); letter-spacing:0.07em; text-transform:uppercase;">Serviços</div>
                @if (_isAdmin && !_editingServicos)
                {
                    <button @onclick="StartEditServicos"
                            style="width:28px; height:28px; border-radius:var(--r-full); border:1px solid var(--border); background:var(--bg-page); cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        <i class="fa-solid fa-pen" style="font-size:10px; color:var(--text-3);"></i>
                    </button>
                }
            </div>

            @if (!_editingServicos)
            {
                <div style="display:flex; flex-wrap:wrap; gap:8px;">
                    @foreach (var s in _servicos)
                    {
                        <div style="display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:500; padding:5px 11px; border-radius:var(--r-full); font-family:var(--font); border:1px solid @(s.Ok ? "#BBF7D0" : "var(--border)"); background:@(s.Ok ? "var(--green-bg)" : "var(--bg-page)"); color:@(s.Ok ? "var(--green)" : "var(--text-4)");">
                            <i class="fa-solid @s.Icon" style="font-size:10px;"></i>
                            <span>@s.Label</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="display:flex; flex-wrap:wrap; gap:8px;">
                    <button @onclick="@(() => _eTemTomada = !_eTemTomada)" style="@ChipToggleStyle(_eTemTomada)">
                        <i class="fa-solid fa-plug" style="font-size:10px;"></i> Tomada
                    </button>
                    <button @onclick="@(() => _eTemCalibrador = !_eTemCalibrador)" style="@ChipToggleStyle(_eTemCalibrador)">
                        <i class="fa-solid fa-gauge" style="font-size:10px;"></i> Calibrador
                    </button>
                    <button @onclick="@(() => _eTemVestiario = !_eTemVestiario)" style="@ChipToggleStyle(_eTemVestiario)">
                        <i class="fa-solid fa-shirt" style="font-size:10px;"></i> Vestiário
                    </button>
                    <button @onclick="@(() => _eTemArmario = !_eTemArmario)" style="@ChipToggleStyle(_eTemArmario)">
                        <i class="fa-solid fa-box" style="font-size:10px;"></i> Armário
                    </button>
                    <button @onclick="@(() => _eTemEspacoManutencao = !_eTemEspacoManutencao)" style="@ChipToggleStyle(_eTemEspacoManutencao)">
                        <i class="fa-solid fa-wrench" style="font-size:10px;"></i> Manutenção
                    </button>
                    <button @onclick="@(() => _eTemCadeado = !_eTemCadeado)" style="@ChipToggleStyle(_eTemCadeado)">
                        <i class="fa-solid fa-lock" style="font-size:10px;"></i> Cadeado
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_saveError))
                {
                    <div style="font-size:12px; color:#DC2626; margin-top:8px; font-family:var(--font);">@_saveError</div>
                }
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:12px;">
                    <BtnP OnClick="SaveServicos" Style="@(_isSaving ? "opacity:0.6; pointer-events:none;" : "")">
                        @(_isSaving ? "Salvando..." : "Salvar")
                    </BtnP>
                    <BtnO OnClick="@(() => { _editingServicos = false; _saveError = null; })">Cancelar</BtnO>
                </div>
            }
        </div>

        @* Access + Vehicles 2-col (stacks to 1-col when editing either) *@
        <div style="display:grid; grid-template-columns:@(_editingAcesso || _editingVeiculos ? "1fr" : "1fr 1fr"); gap:10px; margin-bottom:20px; transition:grid-template-columns 0.15s;">

            @* Acesso card *@
            <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid @(_editingAcesso ? "var(--brand)" : "var(--border)"); padding:14px; box-shadow:var(--shadow-xs); transition:border-color 0.15s;">
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:8px;">
                    <div style="font-family:var(--font); font-size:11px; font-weight:600; color:var(--text-4); letter-spacing:0.07em; text-transform:uppercase;">Acesso</div>
                    @if (_isAdmin && !_editingAcesso)
                    {
                        <button @onclick="StartEditAcesso"
                                style="width:28px; height:28px; border-radius:var(--r-full); border:1px solid var(--border); background:var(--bg-page); cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <i class="fa-solid fa-pen" style="font-size:10px; color:var(--text-3);"></i>
                        </button>
                    }
                </div>

                @if (!_editingAcesso)
                {
                    <div>
                        @if (_item.AcessoLivre)
                        {
                            <Chip Accent="true" Sm="true">Livre</Chip>
                        }
                        else if (_item.AcessoPago)
                        {
                            <Chip Sm="true">Pago</Chip>
                        }
                        else if (_item.AcessoCadastro)
                        {
                            <Chip Sm="true">Cadastro</Chip>
                        }
                        else if (_item.AcessoMensal)
                        {
                            <Chip Sm="true">Mensal</Chip>
                        }
                        else
                        {
                            <span style="font-size:13px; color:var(--text-4); font-family:var(--font);">—</span>
                        }
                    </div>
                }
                else
                {
                    <div style="display:flex; flex-direction:column; gap:6px;">
                        @foreach (var (key, label) in new[] { ("livre","Livre"), ("pago","Pago"), ("cadastro","Cadastro"), ("mensal","Mensal") })
                        {
                            var isSelected = _eAcesso == key;
                            <button @onclick="@(() => _eAcesso = isSelected ? "" : key)"
                                    style="display:flex; align-items:center; gap:8px; padding:8px 12px; border-radius:var(--r); border:1px solid @(isSelected ? "var(--brand)" : "var(--border)"); background:@(isSelected ? "var(--brand-soft)" : "var(--bg-page)"); cursor:pointer; font-family:var(--font); font-size:13px; font-weight:@(isSelected ? "600" : "400"); color:@(isSelected ? "var(--brand)" : "var(--text-3)"); text-align:left; -webkit-appearance:none; width:100%;">
                                <i class="fa-solid @(isSelected ? "fa-circle-dot" : "fa-circle")" style="font-size:11px;"></i>
                                @label
                            </button>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(_saveError))
                    {
                        <div style="font-size:12px; color:#DC2626; margin-top:8px; font-family:var(--font);">@_saveError</div>
                    }
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:12px;">
                        <BtnP OnClick="SaveAcesso" Style="@(_isSaving ? "opacity:0.6; pointer-events:none;" : "")">
                            @(_isSaving ? "Salvando..." : "Salvar")
                        </BtnP>
                        <BtnO OnClick="@(() => { _editingAcesso = false; _saveError = null; })">Cancelar</BtnO>
                    </div>
                }
            </div>

            @* Veículos card *@
            <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid @(_editingVeiculos ? "var(--brand)" : "var(--border)"); padding:14px; box-shadow:var(--shadow-xs); transition:border-color 0.15s;">
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:8px;">
                    <div style="font-family:var(--font); font-size:11px; font-weight:600; color:var(--text-4); letter-spacing:0.07em; text-transform:uppercase;">Veículos</div>
                    @if (_isAdmin && !_editingVeiculos)
                    {
                        <button @onclick="StartEditVeiculos"
                                style="width:28px; height:28px; border-radius:var(--r-full); border:1px solid var(--border); background:var(--bg-page); cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <i class="fa-solid fa-pen" style="font-size:10px; color:var(--text-3);"></i>
                        </button>
                    }
                </div>

                @if (!_editingVeiculos)
                {
                    <div style="display:flex; flex-wrap:wrap; gap:6px;">
                        @if (_veiculos.Count == 0)
                        {
                            <span style="font-size:13px; color:var(--text-4); font-family:var(--font);">—</span>
                        }
                        @foreach (var v in _veiculos)
                        {
                            <Chip Sm="true">
                                <i class="fa-solid @v.Icon" style="font-size:10px;"></i>&nbsp;@v.Label
                            </Chip>
                        }
                    </div>
                }
                else
                {
                    <div style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:4px;">
                        <button @onclick="@(() => _eVeicBicicleta = !_eVeicBicicleta)" style="@ChipToggleStyle(_eVeicBicicleta)">
                            <i class="fa-solid fa-bicycle" style="font-size:10px;"></i> Bicicleta
                        </button>
                        <button @onclick="@(() => _eVeicScooter = !_eVeicScooter)" style="@ChipToggleStyle(_eVeicScooter)">
                            <i class="fa-solid fa-person-biking" style="font-size:10px;"></i> Scooter
                        </button>
                        <button @onclick="@(() => _eVeicMonociclo = !_eVeicMonociclo)" style="@ChipToggleStyle(_eVeicMonociclo)">
                            <i class="fa-solid fa-circle-dot" style="font-size:10px;"></i> Monociclo
                        </button>
                        <button @onclick="@(() => _eVeicPatinete = !_eVeicPatinete)" style="@ChipToggleStyle(_eVeicPatinete)">
                            <i class="fa-solid fa-bolt" style="font-size:10px;"></i> Patinete
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(_saveError))
                    {
                        <div style="font-size:12px; color:#DC2626; margin-top:8px; font-family:var(--font);">@_saveError</div>
                    }
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:12px;">
                        <BtnP OnClick="SaveVeiculos" Style="@(_isSaving ? "opacity:0.6; pointer-events:none;" : "")">
                            @(_isSaving ? "Salvando..." : "Salvar")
                        </BtnP>
                        <BtnO OnClick="@(() => { _editingVeiculos = false; _saveError = null; })">Cancelar</BtnO>
                    </div>
                }
            </div>
        </div>

        @* Operator badge *@
        @if (!string.IsNullOrEmpty(_item.NomeOperador))
        {
            <div style="display:flex; align-items:center; gap:12px; padding:14px 16px; background:var(--brand-soft); border-radius:var(--r-lg); border:1px solid var(--red-bg); margin-bottom:20px;">
                <div style="width:36px; height:36px; border-radius:var(--r-full); background:var(--brand); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fa-solid fa-store" style="color:white; font-size:14px;"></i>
                </div>
                <div>
                    <div style="font-size:10px; color:var(--brand); font-weight:700; font-family:var(--font); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:2px;">Operador verificado</div>
                    <div style="font-size:14px; color:var(--text-2); font-family:var(--font); font-weight:600;">@_item.NomeOperador</div>
                </div>
            </div>
        }

        @* Reviews *@
        <div style="margin-bottom:12px;">
            <div style="font-family:var(--font); font-size:11px; font-weight:600; color:var(--text-4); letter-spacing:0.07em; text-transform:uppercase;">
                Avaliações (@(_item.Avaliacoes.Length))
            </div>
        </div>

        @if (_item.Avaliacoes.Length == 0)
        {
            <div style="text-align:center; padding:30px 20px; background:var(--bg); border-radius:var(--r-lg); border:1px solid var(--border); margin-bottom:12px;">
                <i class="fa-regular fa-comment-dots" style="font-size:30px; color:var(--text-4); display:block; margin-bottom:10px;"></i>
                <div style="font-size:14px; color:var(--text-3); font-family:var(--font); line-height:1.5;">
                    Nenhuma avaliação ainda.<br />
                    <span style="color:var(--brand); font-weight:600;">Seja o primeiro!</span>
                </div>
            </div>
        }

        @foreach (var r in _item.Avaliacoes.OrderByDescending(x => x.CriadoEm).Take(10))
        {
            <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid var(--border); padding:14px; margin-bottom:10px; box-shadow:var(--shadow-xs);">
                <div style="display:flex; align-items:center; gap:10px; @(string.IsNullOrEmpty(r.Comentario) ? "" : "margin-bottom:8px;")">
                    <div style="width:32px; height:32px; border-radius:var(--r-full); background:var(--bg-page); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        <i class="fa-solid fa-user" style="font-size:13px; color:var(--text-4);"></i>
                    </div>
                    <div style="flex:1; min-width:0;">
                        <div style="font-size:13px; font-weight:600; color:var(--text); font-family:var(--font);">@r.NomeUsuario</div>
                        <div style="font-size:11px; color:var(--text-4); font-family:var(--font); margin-top:1px;">@FormatDate(r.CriadoEm)</div>
                    </div>
                    <Stars N="@r.Nota" Size="12" />
                </div>
                @if (!string.IsNullOrEmpty(r.Comentario))
                {
                    <p style="font-size:13px; color:var(--text-2); font-family:var(--font); line-height:1.55; margin:0;">@r.Comentario</p>
                }
            </div>
        }

        @* Admin danger zone *@
        @if (_isAdmin)
        {
            <div style="margin-top:24px; padding:16px; border:1px solid #FCA5A5; border-radius:var(--r-lg); background:#FFF5F5;">
                <div style="font-size:11px; font-weight:700; color:#DC2626; font-family:var(--font); text-transform:uppercase; letter-spacing:0.07em; margin-bottom:4px;">
                    <i class="fa-solid fa-triangle-exclamation" style="margin-right:6px;"></i>
                    Zona Admin
                </div>
                <div style="font-size:12px; color:#9B1C1C; font-family:var(--font); margin-bottom:14px; line-height:1.4;">
                    Ocultar faz soft delete (reversível). Excluir apaga permanentemente todos os dados.
                </div>
                @if (!string.IsNullOrEmpty(_deleteError))
                {
                    <div style="font-size:12px; color:#DC2626; margin-bottom:10px; font-family:var(--font);">@_deleteError</div>
                }
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
                    <button @onclick="SoftDelete"
                            style="padding:11px 8px; border-radius:var(--r-lg); border:1px solid #F59E0B; background:#FEF3C7; color:#92400E; font-family:var(--font); font-size:13px; font-weight:600; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:6px; -webkit-appearance:none;">
                        <i class="fa-solid fa-eye-slash" style="font-size:12px;"></i> Ocultar
                    </button>
                    <button @onclick="HardDelete"
                            style="padding:11px 8px; border-radius:var(--r-lg); border:1px solid #EF4444; background:#FEE2E2; color:#DC2626; font-family:var(--font); font-size:13px; font-weight:600; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:6px; -webkit-appearance:none;">
                        <i class="fa-solid fa-trash" style="font-size:12px;"></i> Excluir
                    </button>
                </div>
            </div>
        }

    </div>@* /scrollable body *@

    @* Sticky CTA above BottomNav *@
    <div style="position:absolute; bottom:82px; left:16px; right:16px;">
        <BtnP OnClick="@(() => Nav.NavigateTo($"/avaliar/{Id}?name={Uri.EscapeDataString(_item.Nome)}"))">
            <i class="fa-regular fa-star" style="margin-right:8px;"></i>Avaliar este local
        </BtnP>
    </div>
}

<BottomNav Active="lista" />

@code {
    [Parameter] public string? Id { get; set; }

    private BicicletarioDetalheModel? _item;
    private bool    _isLoading = true;
    private string? _loadError;
    private string? _address;

    private UserInfo? _userInfo;
    private bool      _isAdmin;
    private string?   _fotoUrl;
    private bool      _fotoFalhou;
    private bool      _lightboxOpen;

    // Edit mode flags (only one section active at a time)
    private bool _editingFoto;
    private bool _editingServicos;
    private bool _editingAcesso;
    private bool _editingVeiculos;

    // Edit state — serviços
    private bool _eTemTomada, _eTemCalibrador, _eTemVestiario, _eTemArmario, _eTemEspacoManutencao, _eTemCadeado;

    // Edit state — acesso (single selection key: "livre" | "pago" | "cadastro" | "mensal" | "")
    private string _eAcesso = "";

    // Edit state — veículos (bitmask flags)
    private bool _eVeicBicicleta, _eVeicScooter, _eVeicMonociclo, _eVeicPatinete;

    private bool    _isSaving;
    private string? _saveError;
    private string? _deleteError;

    // Pre-computed display data
    private (string Icon, string Label, bool Ok)[] _servicos = [];
    private List<(string Icon, string Label)>       _veiculos = [];

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Id))
        {
            _loadError = "ID inválido.";
            _isLoading = false;
            return;
        }

        var userTask = AuthSvc.GetUserInfoAsync();
        var itemTask = BicicletarioSvc.GetByIdAsync(Id);
        await Task.WhenAll(userTask, itemTask);

        _userInfo = userTask.Result;
        _isAdmin  = _userInfo?.Type == 2;
        _item     = itemTask.Result;
        _isLoading = false;

        if (_item == null)
        {
            _loadError = "Bicicletário não encontrado ou servidor indisponível.";
            return;
        }

        RecomputeDisplayData();

        _ = ReverseGeocodeAsync(_item.Latitude, _item.Longitude);
        _fotoUrl = BicicletarioSvc.GetFotoBicicletarioUrl(Id!);
    }

    private void RecomputeDisplayData()
    {
        _servicos =
        [
            ("fa-plug",   "Tomada",     _item!.TemTomada),
            ("fa-gauge",  "Calibrador", _item!.TemCalibrador),
            ("fa-shirt",  "Vestiário",  _item!.TemVestiario),
            ("fa-box",    "Armário",    _item!.TemArmario),
            ("fa-wrench", "Manutenção", _item!.TemEspacoManutencao),
            ("fa-lock",   "Cadeado",    _item!.TemCadeado),
        ];

        _veiculos = [];
        if ((_item!.VeiculosSuportados & 1) != 0) _veiculos.Add(("fa-bicycle",       "Bicicleta"));
        if ((_item!.VeiculosSuportados & 2) != 0) _veiculos.Add(("fa-person-biking", "Scooter"));
        if ((_item!.VeiculosSuportados & 4) != 0) _veiculos.Add(("fa-circle-dot",    "Monociclo"));
        if ((_item!.VeiculosSuportados & 8) != 0) _veiculos.Add(("fa-bolt",          "Patinete"));
    }

    // ─── Edit initiators ────────────────────────────────────────────────────

    private void StartEditServicos()
    {
        _eTemTomada           = _item!.TemTomada;
        _eTemCalibrador       = _item!.TemCalibrador;
        _eTemVestiario        = _item!.TemVestiario;
        _eTemArmario          = _item!.TemArmario;
        _eTemEspacoManutencao = _item!.TemEspacoManutencao;
        _eTemCadeado          = _item!.TemCadeado;
        _editingServicos = true;
        _editingAcesso   = false;
        _editingVeiculos = false;
        _editingFoto     = false;
        _saveError       = null;
    }

    private void StartEditAcesso()
    {
        _eAcesso = _item!.AcessoLivre    ? "livre"    :
                   _item!.AcessoPago     ? "pago"     :
                   _item!.AcessoCadastro ? "cadastro" :
                   _item!.AcessoMensal   ? "mensal"   : "";
        _editingAcesso   = true;
        _editingServicos = false;
        _editingVeiculos = false;
        _editingFoto     = false;
        _saveError       = null;
    }

    private void StartEditVeiculos()
    {
        _eVeicBicicleta = (_item!.VeiculosSuportados & 1) != 0;
        _eVeicScooter   = (_item!.VeiculosSuportados & 2) != 0;
        _eVeicMonociclo = (_item!.VeiculosSuportados & 4) != 0;
        _eVeicPatinete  = (_item!.VeiculosSuportados & 8) != 0;
        _editingVeiculos = true;
        _editingServicos = false;
        _editingAcesso   = false;
        _editingFoto     = false;
        _saveError       = null;
    }

    // ─── Save handlers ──────────────────────────────────────────────────────

    private async Task SaveServicos()
    {
        _isSaving  = true;
        _saveError = null;
        var err = await BicicletarioSvc.UpdateAsync(Id!, new AdminUpdateRequest
        {
            TemTomada           = _eTemTomada,
            TemCalibrador       = _eTemCalibrador,
            TemVestiario        = _eTemVestiario,
            TemArmario          = _eTemArmario,
            TemEspacoManutencao = _eTemEspacoManutencao,
            TemCadeado          = _eTemCadeado,
        });
        if (err == null)
        {
            _item!.TemTomada           = _eTemTomada;
            _item!.TemCalibrador       = _eTemCalibrador;
            _item!.TemVestiario        = _eTemVestiario;
            _item!.TemArmario          = _eTemArmario;
            _item!.TemEspacoManutencao = _eTemEspacoManutencao;
            _item!.TemCadeado          = _eTemCadeado;
            RecomputeDisplayData();
            _editingServicos = false;
        }
        else _saveError = err;
        _isSaving = false;
    }

    private async Task SaveAcesso()
    {
        _isSaving  = true;
        _saveError = null;
        var err = await BicicletarioSvc.UpdateAsync(Id!, new AdminUpdateRequest
        {
            AcessoLivre     = _eAcesso == "livre",
            AcessoPago      = _eAcesso == "pago",
            AcessoCadastro  = _eAcesso == "cadastro",
            AcessoMensal    = _eAcesso == "mensal",
        });
        if (err == null)
        {
            _item!.AcessoLivre    = _eAcesso == "livre";
            _item!.AcessoPago     = _eAcesso == "pago";
            _item!.AcessoCadastro = _eAcesso == "cadastro";
            _item!.AcessoMensal   = _eAcesso == "mensal";
            _editingAcesso = false;
        }
        else _saveError = err;
        _isSaving = false;
    }

    private async Task SaveVeiculos()
    {
        _isSaving  = true;
        _saveError = null;
        var flags = (_eVeicBicicleta ? 1 : 0) | (_eVeicScooter ? 2 : 0)
                  | (_eVeicMonociclo ? 4 : 0) | (_eVeicPatinete ? 8 : 0);
        var err = await BicicletarioSvc.UpdateAsync(Id!, new AdminUpdateRequest
        {
            VeiculosSuportados = flags,
        });
        if (err == null)
        {
            _item!.VeiculosSuportados = flags;
            RecomputeDisplayData();
            _editingVeiculos = false;
        }
        else _saveError = err;
        _isSaving = false;
    }

    private async Task HandleFotoUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > 5 * 1024 * 1024)
        {
            _saveError = "Arquivo muito grande. Máximo 5MB.";
            return;
        }
        _isSaving  = true;
        _saveError = null;
        try
        {
            using var content = new MultipartFormDataContent();
            using var stream  = file.OpenReadStream(5 * 1024 * 1024);
            using var sc      = new StreamContent(stream);
            sc.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
            content.Add(sc, "foto", file.Name);
            var err = await BicicletarioSvc.UploadFotoAsync(Id!, content);
            if (err == null)
            {
                _fotoFalhou = false;
                _fotoUrl = BicicletarioSvc.GetFotoBicicletarioUrl(Id!, DateTimeOffset.UtcNow.ToUnixTimeSeconds());
                _editingFoto = false;
            }
            else _saveError = err;
        }
        finally { _isSaving = false; }
    }

    // ─── Delete handlers ─────────────────────────────────────────────────────

    private async Task SoftDelete()
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Ocultar '{_item?.Nome}'?\nEle ficará invisível na listagem mas os dados são preservados."))
            return;
        _deleteError = null;
        var err = await BicicletarioSvc.SoftDeleteAsync(Id!);
        if (err == null) Nav.NavigateTo("/lista");
        else _deleteError = err;
    }

    private async Task HardDelete()
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"⚠️ EXCLUIR PERMANENTEMENTE '{_item?.Nome}'?\nTodos os dados e avaliações serão apagados. Isso não pode ser desfeito."))
            return;
        if (!await JS.InvokeAsync<bool>("confirm", "Tem certeza absoluta? Esta ação é irreversível."))
            return;
        _deleteError = null;
        var err = await BicicletarioSvc.HardDeleteAsync(Id!);
        if (err == null) Nav.NavigateTo("/lista");
        else _deleteError = err;
    }

    // ─── Utilities ───────────────────────────────────────────────────────────

    private static string ChipToggleStyle(bool active) =>
        $"display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:500; padding:5px 11px; border-radius:var(--r-full); font-family:var(--font); border:1px solid {(active ? "#BBF7D0" : "var(--border)")}; background:{(active ? "var(--green-bg)" : "var(--bg-page)")}; color:{(active ? "var(--green)" : "var(--text-4)")}; cursor:pointer; -webkit-appearance:none; gap:6px;";

    private async Task ReverseGeocodeAsync(double lat, double lng)
    {
        try
        {
            var geo = HttpFactory.CreateClient("geocoder");
            var result = await geo.GetFromJsonAsync<NominatimReverseResult>(
                $"reverse?format=json&lat={lat.ToString(CultureInfo.InvariantCulture)}&lon={lng.ToString(CultureInfo.InvariantCulture)}");

            if (result?.Address is { } addr)
            {
                var parts = new List<string>(3);
                if (!string.IsNullOrEmpty(addr.Road)) parts.Add(addr.Road);
                var bairro = addr.Suburb ?? addr.CityDistrict;
                if (!string.IsNullOrEmpty(bairro)) parts.Add(bairro);
                if (!string.IsNullOrEmpty(addr.City)) parts.Add(addr.City);
                _address = parts.Count > 0 ? string.Join(", ", parts) : result.DisplayName;
            }
            else if (result is { DisplayName: { } dn })
            {
                _address = dn.Length > 70 ? dn[..67] + "..." : dn;
            }

            StateHasChanged();
        }
        catch { /* address stays null — harmless */ }
    }

    private static string FormatDate(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt.ToUniversalTime();
        if (diff.TotalMinutes < 2)  return "agora";
        if (diff.TotalHours  < 1)   return $"há {(int)diff.TotalMinutes} min";
        if (diff.TotalDays   < 1)   return $"há {(int)diff.TotalHours}h";
        if (diff.TotalDays   < 2)   return "ontem";
        if (diff.TotalDays   < 30)  return $"há {(int)diff.TotalDays} dias";
        var meses = (int)(diff.TotalDays / 30);
        if (diff.TotalDays   < 365) return $"há {meses} {(meses == 1 ? "mês" : "meses")}";
        var anos = (int)(diff.TotalDays / 365);
        return $"há {anos} ano{(anos > 1 ? "s" : "")}";
    }

    private class NominatimReverseResult
    {
        [JsonPropertyName("display_name")] public string?          DisplayName { get; set; }
        [JsonPropertyName("address")]      public NominatimAddress? Address     { get; set; }
    }

    private class NominatimAddress
    {
        [JsonPropertyName("road")]          public string? Road         { get; set; }
        [JsonPropertyName("suburb")]        public string? Suburb       { get; set; }
        [JsonPropertyName("city_district")] public string? CityDistrict { get; set; }
        [JsonPropertyName("city")]          public string? City         { get; set; }
    }
}
