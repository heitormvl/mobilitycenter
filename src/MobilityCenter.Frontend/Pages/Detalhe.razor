@page "/bicicletario/{Id}"
@inject NavigationManager Nav

<!-- Header -->
<div style="background:var(--bg); border-bottom:1px solid var(--border); position:sticky; top:0; z-index:20;">
    <StatusBar />
    <div style="display:flex; align-items:center; gap:14px; padding:4px 20px 14px;">
        <button @onclick="@(() => Nav.NavigateTo("/lista"))" style="width:36px; height:36px; border-radius:var(--r-full); background:var(--bg-page); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
            <i class="fa-solid fa-chevron-left" style="color:var(--text-2); font-size:13px;"></i>
        </button>
        <span style="font-size:17px; font-weight:700; color:var(--text); font-family:var(--font); letter-spacing:-0.02em; flex:1;">Bicicletário Central</span>
        <button style="width:36px; height:36px; border-radius:var(--r-full); background:var(--bg-page); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center;">
            <i class="fa-solid fa-share-nodes" style="color:var(--text-3); font-size:14px;"></i>
        </button>
        <button style="width:36px; height:36px; border-radius:var(--r-full); background:var(--bg-page); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center;">
            <i class="fa-regular fa-bookmark" style="color:var(--text-3); font-size:14px;"></i>
        </button>
    </div>
</div>

<!-- Photo -->
<ImgPH H="200" Label="Foto do local" />

<!-- Content -->
<div style="padding:20px 20px 100px;">

    <!-- Rating + address -->
    <div style="margin-bottom:20px;">
        <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px;">
            <Stars N="4" Size="15" />
            <span style="font-size:14px; font-weight:600; color:var(--text); font-family:var(--font);">4,2</span>
            <span style="font-size:13px; color:var(--text-4); font-family:var(--font);">· 23 avaliações</span>
        </div>
        <div style="display:flex; align-items:center; gap:6px; color:var(--text-3); font-size:13px; font-family:var(--font);">
            <i class="fa-solid fa-location-dot" style="color:var(--brand); font-size:12px;"></i>
            Rua das Flores, 123 · Centro · 0,3 km
        </div>
    </div>

    <!-- Services -->
    <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid var(--border); padding:16px; margin-bottom:12px;">
        <SecLabel>Serviços</SecLabel>
        <div style="display:flex; flex-wrap:wrap; gap:8px;">
            @foreach (var s in _servicos)
            {
                <div style="display:flex; align-items:center; gap:6px; font-size:12px; font-weight:500; padding:5px 11px; border-radius:var(--r-full); background:@(s.Ok ? "var(--green-bg)" : "var(--bg-page)"); color:@(s.Ok ? "var(--green)" : "var(--text-4)"); font-family:var(--font);">
                    <i class="fa-solid @s.Icon" style="font-size:10px;"></i>
                    <span>@s.Label</span>
                </div>
            }
        </div>
    </div>

    <!-- Access + Vehicles -->
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:20px;">
        <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid var(--border); padding:14px;">
            <SecLabel>Acesso</SecLabel>
            <Chip Accent="true" Sm="true">Livre</Chip>
        </div>
        <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid var(--border); padding:14px;">
            <SecLabel>Veículos</SecLabel>
            <div style="display:flex; flex-wrap:wrap; gap:6px;">
                <Chip Sm="true"><i class="fa-solid fa-bicycle" style="font-size:10px;"></i></Chip>
                <Chip Sm="true">Patinete</Chip>
            </div>
        </div>
    </div>

    <!-- Reviews -->
    <SecLabel>Avaliações recentes</SecLabel>
    @foreach (var r in _avaliacoes)
    {
        <div style="background:var(--bg); border-radius:var(--r-lg); border:1px solid var(--border); padding:14px; margin-bottom:10px;">
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:8px;">
                <div style="width:32px; height:32px; border-radius:var(--r-full); background:var(--bg-page); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fa-solid fa-user" style="font-size:13px; color:var(--text-4);"></i>
                </div>
                <div style="flex:1;">
                    <div style="font-size:13px; font-weight:600; color:var(--text); font-family:var(--font);">@r.User</div>
                </div>
                <Stars N="@r.Stars" Size="12" />
            </div>
            <p style="font-size:13px; color:var(--text-2); font-family:var(--font); line-height:1.5; margin:0;">@r.Text</p>
        </div>
    }
</div>

<!-- CTA -->
<div style="position:absolute; bottom:80px; left:16px; right:16px;">
    <BtnP OnClick="@(() => Nav.NavigateTo("/avaliar/1"))">Avaliar este local</BtnP>
</div>

<BottomNav Active="lista" />

@code {
    [Parameter] public string? Id { get; set; }

    private readonly (string Icon, string Label, bool Ok)[] _servicos =
    [
        ("fa-plug",   "Tomada",     true),
        ("fa-gauge",  "Calibrador", true),
        ("fa-box",    "Armário",    false),
        ("fa-wrench", "Manutenção", true),
        ("fa-lock",   "Cadeado",    false),
    ];

    private readonly (string User, string Text, int Stars)[] _avaliacoes =
    [
        ("Ana P.",    "Ótimo local, sempre organizado!",          5),
        ("Carlos M.", "Calibrador parou de funcionar na visita.", 3),
    ];
}
