@page "/login"
@implements IDisposable
@inject NavigationManager Nav
@inject AuthService AuthService
@inject IJSRuntime JS
@inject IConfiguration Config

<div style="min-height:100vh; display:flex; flex-direction:column; background:linear-gradient(160deg, var(--brand) 0%, var(--brand-dark) 100%);">

    <StatusBar />

    <!-- Hero -->
    <div style="padding:36px 28px 60px; text-align:center; flex-shrink:0;">
        <div style="width:76px; height:76px; border-radius:24px; background:rgba(255,255,255,0.18); backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px); border:1.5px solid rgba(255,255,255,0.28); margin:0 auto 20px; display:flex; align-items:center; justify-content:center;">
            <i class="fa-solid fa-bicycle" style="font-size:34px; color:white;"></i>
        </div>
        <h1 style="font-size:28px; font-weight:800; color:white; font-family:var(--font); letter-spacing:-0.03em; margin-bottom:6px; text-shadow:0 2px 8px rgba(0,0,0,0.18);">MobilityCenter</h1>
        <p style="font-size:14px; color:rgba(255,255,255,0.72); font-family:var(--font);">Micromobilidade colaborativa</p>
    </div>

    <!-- Card -->
    <div style="flex:1; background:var(--bg); border-radius:28px 28px 0 0; box-shadow:0 -6px 40px rgba(0,0,0,0.18); margin-top:-32px; overflow:hidden;">
        <div style="display:flex; transition:transform 0.34s cubic-bezier(0.4,0,0.2,1); transform:@SlideTransform; will-change:transform;">

            <!-- Login panel -->
            <div style="min-width:100%; flex-shrink:0; padding:32px 24px 52px;">
                <p style="font-size:22px; font-weight:800; color:var(--text); font-family:var(--font); letter-spacing:-0.03em; margin-bottom:4px;">Bem-vindo de volta</p>
                <p style="font-size:14px; color:var(--text-3); font-family:var(--font); margin-bottom:28px;">Entre na sua conta para continuar</p>

                <div style="display:flex; flex-direction:column; gap:16px; margin-bottom:24px;">
                    <div>
                        <label style="display:block; font-size:13px; font-weight:500; color:var(--text-2); margin-bottom:8px; font-family:var(--font);">E-mail</label>
                        <WfInput @bind-Value="_email" Placeholder="seu@email.com" IconClass="fa-envelope" />
                    </div>
                    <div>
                        <label style="display:block; font-size:13px; font-weight:500; color:var(--text-2); margin-bottom:8px; font-family:var(--font);">Senha</label>
                        <WfInput @bind-Value="_password" Placeholder="••••••••" IconClass="fa-lock" Type="password" />
                    </div>
                    <div style="text-align:right;">
                        <span style="font-size:13px; color:var(--brand); font-weight:600; cursor:pointer; font-family:var(--font);">Esqueci minha senha</span>
                    </div>
                </div>

                @if (_error != null && !_showRegister)
                {
                    <div style="background:var(--red-bg); border:1px solid var(--red-border); border-radius:var(--r); padding:12px 14px; margin-bottom:16px; font-family:var(--font); font-size:13px; color:var(--red);">
                        @_error
                    </div>
                }

                <BtnP Style="margin-bottom:20px;" OnClick="HandleLogin">
                    @if (_loading) { <span>Entrando...</span> } else { <span>Entrar</span> }
                </BtnP>

                <div style="display:flex; align-items:center; gap:14px; margin-bottom:20px;">
                    <div style="flex:1; height:1px; background:var(--border);"></div>
                    <span style="font-size:12px; color:var(--text-4); font-family:var(--font); font-weight:500;">OU</span>
                    <div style="flex:1; height:1px; background:var(--border);"></div>
                </div>

                <BtnO OnClick="HandleGoogleLogin">
                    @if (_googleLoading)
                    {
                        <i class="fa-solid fa-spinner fa-spin" style="font-size:14px;"></i>
                        <span>Entrando com Google...</span>
                    }
                    else
                    {
                        <svg width="18" height="18" viewBox="0 0 18 18" style="flex-shrink:0;">
                            <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 01-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
                            <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z" fill="#34A853"/>
                            <path d="M3.964 10.71A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
                            <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
                        </svg>
                        <span>Continuar com Google</span>
                    }
                </BtnO>

                <div style="text-align:center; margin-top:32px; font-size:15px; font-family:var(--font);">
                    <span style="color:var(--text-3);">Não tem conta? </span>
                    <span @onclick="@(() => { _showRegister = true; _error = null; })" style="color:var(--brand); font-weight:600; cursor:pointer;">Criar conta</span>
                </div>
            </div>

            <!-- Register panel -->
            <div style="min-width:100%; flex-shrink:0; padding:32px 24px 52px;">
                <p style="font-size:22px; font-weight:800; color:var(--text); font-family:var(--font); letter-spacing:-0.03em; margin-bottom:4px;">Criar conta</p>
                <p style="font-size:14px; color:var(--text-3); font-family:var(--font); margin-bottom:28px;">Preencha seus dados para começar</p>

                <div style="display:flex; flex-direction:column; gap:16px; margin-bottom:24px;">
                    <div>
                        <label style="display:block; font-size:13px; font-weight:500; color:var(--text-2); margin-bottom:8px; font-family:var(--font);">Nome</label>
                        <WfInput @bind-Value="_displayName" Placeholder="Seu nome completo" IconClass="fa-user" />
                    </div>
                    <div>
                        <label style="display:block; font-size:13px; font-weight:500; color:var(--text-2); margin-bottom:8px; font-family:var(--font);">E-mail</label>
                        <WfInput @bind-Value="_email" Placeholder="seu@email.com" IconClass="fa-envelope" />
                    </div>
                    <div>
                        <label style="display:block; font-size:13px; font-weight:500; color:var(--text-2); margin-bottom:8px; font-family:var(--font);">Senha</label>
                        <WfInput @bind-Value="_password" Placeholder="Mínimo 6 caracteres" IconClass="fa-lock" Type="password" />
                    </div>
                </div>

                @if (_error != null && _showRegister)
                {
                    <div style="background:var(--red-bg); border:1px solid var(--red-border); border-radius:var(--r); padding:12px 14px; margin-bottom:16px; font-family:var(--font); font-size:13px; color:var(--red);">
                        @_error
                    </div>
                }

                <BtnP Style="margin-bottom:20px;" OnClick="HandleRegister">
                    @if (_loading) { <span>Criando conta...</span> } else { <span>Criar conta</span> }
                </BtnP>

                <div style="text-align:center; margin-top:8px; font-size:15px; font-family:var(--font);">
                    <span style="color:var(--text-3);">Já tem conta? </span>
                    <span @onclick="@(() => { _showRegister = false; _error = null; })" style="color:var(--brand); font-weight:600; cursor:pointer;">Entrar</span>
                </div>
            </div>

        </div>
    </div>
</div>

@code {
    private string _email = "";
    private string _password = "";
    private string _displayName = "";
    private bool _loading;
    private bool _googleLoading;
    private string? _error;
    private bool _showRegister;
    private DotNetObjectReference<Login>? _dotNetRef;

    private string SlideTransform => _showRegister ? "translateX(-100%)" : "translateX(0)";

    protected override void OnInitialized() =>
        _dotNetRef = DotNetObjectReference.Create(this);

    private async Task HandleGoogleLogin()
    {
        if (_googleLoading) return;
        _googleLoading = true;
        _error = null;
        StateHasChanged();

        var clientId = Config["Google:ClientId"] ?? "";
        await JS.InvokeVoidAsync("googleAuth.signIn", clientId, _dotNetRef);
    }

    [JSInvokable]
    public async Task HandleGoogleCredential(string idToken)
    {
        var erro = await AuthService.LoginWithGoogleAsync(idToken);

        if (erro is null)
            Nav.NavigateTo("/");
        else
            _error = erro;

        _googleLoading = false;
        StateHasChanged();
    }

    [JSInvokable]
    public void HandleGoogleError(string reason)
    {
        _error = reason switch
        {
            "opt_out_or_no_session" => "Nenhuma conta Google detectada neste navegador.",
            "suppressed_by_user"    => "Login com Google foi cancelado.",
            "browser_not_supported" => "Seu navegador não suporta login com Google.",
            "invalid_client"        => "Configuração do Google inválida.",
            _                       => "Não foi possível iniciar o login com Google. Tente novamente."
        };
        _googleLoading = false;
        StateHasChanged();
    }

    public void Dispose() => _dotNetRef?.Dispose();

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Preencha e-mail e senha.";
            return;
        }

        _loading = true;
        _error = null;

        var erro = await AuthService.LoginAsync(_email, _password);

        if (erro is null)
            Nav.NavigateTo(Destination);
        else
            _error = erro;

        _loading = false;
    }

    private async Task HandleRegister()
    {
        if (string.IsNullOrWhiteSpace(_displayName) ||
            string.IsNullOrWhiteSpace(_email) ||
            string.IsNullOrWhiteSpace(_password))
        {
            _error = "Preencha todos os campos.";
            return;
        }

        _loading = true;
        _error = null;

        var erro = await AuthService.RegisterAsync(_displayName, _email, _password);

        if (erro is null)
            Nav.NavigateTo(Destination);
        else
            _error = erro;

        _loading = false;
    }
}
