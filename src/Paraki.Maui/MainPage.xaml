<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Paraki.Maui"
             xmlns:razor="clr-namespace:Paraki.RazorLib;assembly=Paraki.RazorLib"
             xmlns:web="clr-namespace:Microsoft.AspNetCore.Components.Web;assembly=Microsoft.AspNetCore.Components.Web"
             x:Class="Paraki.Maui.MainPage">

    <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
        <BlazorWebView.RootComponents>
            <RootComponent Selector="#app" ComponentType="{x:Type razor:App}" />
            <RootComponent Selector="head::after" ComponentType="{x:Type web:HeadOutlet}" />
        </BlazorWebView.RootComponents>
    </BlazorWebView>

</ContentPage>
